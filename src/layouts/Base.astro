---
import { getSettings, getThemeStyle, getGoogleFontsUrl, getHtmlDataAttrs } from '../config/settings';
import Header from '../components/Header.astro';
import Banner from '../components/Banner.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  variant?: 'default' | 'landing';
  background?: { enabled: boolean; url: string; scrim: 'none' | 'light' | 'medium' | 'strong' };
}

const settings = getSettings();
const themeCss = getThemeStyle(settings);
const fontsUrl = getGoogleFontsUrl(settings);
const htmlAttrs = getHtmlDataAttrs(settings);

const {
  title,
  description = settings.description,
  showHeader = true,
  showFooter = true,
  variant = 'default',
  background,
} = Astro.props;

const bgOn = !!background?.enabled && !!background.url;

const fullTitle = title
  ? `${title} — ${settings.siteName}`
  : `${settings.siteName} — ${settings.tagline}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html {...htmlAttrs}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta name="theme-color" content={settings.colorPaper} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={settings.siteName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme overrides — injected from Theme & Brand singleton -->
    <style is:inline set:html={themeCss}></style>

    <!-- Dynamic Google Fonts based on Theme settings -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />
  </head>

  <body data-variant={variant} data-bg={bgOn ? 'on' : 'off'}>
    {bgOn && (
      <div class="bg-layer" aria-hidden="true">
        <iframe
          class="bg-layer__frame"
          src={background!.url}
          title=""
          tabindex="-1"
          scrolling="no"
          loading="eager"
        ></iframe>
        <div class="bg-layer__scrim" data-scrim={background!.scrim}></div>
      </div>
    )}
    <Banner />
    {showHeader && <Header />}
    <main id="main">
      <slot />
    </main>
    {showFooter && <Footer />}

    <style>
      main { min-height: 60vh; }
      body[data-variant="landing"] main { min-height: 100vh; }

      /* Animated background layer (sits behind all content) */
      body[data-bg="on"] { background: transparent; }
      body[data-bg="on"]::before { display: none; } /* drop grain over the animation */

      .bg-layer {
        position: fixed;
        inset: 0;
        z-index: -1;
        overflow: hidden;
        background: var(--c-paper); /* fallback while the iframe loads */
      }
      .bg-layer__frame {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
        pointer-events: none; /* clicks pass through to the page */
      }
      .bg-layer__scrim {
        position: absolute;
        inset: 0;
        background: var(--c-paper);
      }
      .bg-layer__scrim[data-scrim="none"]   { opacity: 0; }
      .bg-layer__scrim[data-scrim="light"]  { opacity: 0.32; }
      .bg-layer__scrim[data-scrim="medium"] { opacity: 0.55; }
      .bg-layer__scrim[data-scrim="strong"] { opacity: 0.78; }
    </style>
  </body>
</html>
