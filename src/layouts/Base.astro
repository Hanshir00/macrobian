---
import { getLanding, getThemeStyle } from '../config/landing';
import '@fontsource/raleway/400.css';
import '@fontsource/raleway/500.css';
import '@fontsource/raleway/600.css';
import '@fontsource/raleway/700.css';
import '@fontsource/raleway/800.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import Search from '../components/Search.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;

const d = getLanding();
const themeCss = getThemeStyle(d);
const desc = description || d.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} — {d.brandName}</title>
    <meta name="description" content={desc} />
    <meta name="theme-color" content={d.theme.colorBgLight} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} — ${d.brandName}`} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} — ${d.brandName}`} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />

    <style is:inline set:html={themeCss}></style>
  </head>

  <body>
    <header class="topbar" data-pagefind-ignore>
      <a class="brand" href="/">
<span class="brand__sun" aria-hidden="true">
          <svg viewBox="0 0 200 200" fill="none">
            <g class="sun__long" stroke="currentColor" stroke-width="9" stroke-linecap="round">
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(0 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(30 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(60 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(90 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(120 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(150 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(180 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(210 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(240 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(270 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(300 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(330 100 100)"/>
            </g>
            <g class="sun__short" stroke="currentColor" stroke-width="9" stroke-linecap="round">
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(15 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(45 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(75 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(105 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(135 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(165 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(195 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(225 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(255 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(285 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(315 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(345 100 100)"/>
            </g>
          </svg>
        </span>
        <span class="brand__name">{d.brandName}</span>
        <span class="brand__ver">{d.brandVersion}</span>
      </a>
      <nav class="nav" aria-label="Primary">
        {d.nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
      <div class="topbar__right">
        <details class="menu">
          <summary>Menu</summary>
          <nav class="menu__panel" aria-label="Primary">
            {d.nav.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </details>
        <Search />
      </div>
    </header>

    <main class="page" data-pagefind-body>
      <slot />
    </main>

    <footer class="plate" data-pagefind-ignore>
      <span>{d.footerLeft}</span>
      <span>{d.footerCenter}</span>
      <span>{d.footerRight}</span>
    </footer>

    <style>
      body {
        min-height: 100vh;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        background: var(--silver);
      }
      /* film grain — sits on the backdrop, behind all content */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background-image: var(--grain);
        background-size: 160px 160px;
        opacity: 0.05;
        mix-blend-mode: multiply;
      }

      .nav a, .plate span, .brand__name, .brand__ver {
        font-family: var(--f-mono);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: 0.8rem;
      }

      /* Top bar */
      .topbar {
        display: flex; align-items: center; justify-content: space-between;
        padding: clamp(1.4rem, 3vw, 2.4rem) clamp(1.4rem, 4vw, 3.2rem);
        border-bottom: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
      }
      .brand { display: inline-flex; align-items: center; gap: 0.75rem; }
.brand__sun { width: 20px; height: 20px; color: var(--accent); display: inline-flex; flex: none; }
      .brand__sun svg { width: 100%; height: 100%; }
      .sun__long  { transform-origin: 100px 100px; animation: sunSpinCW 24s linear infinite; }
      .sun__short { transform-origin: 100px 100px; animation: sunSpinCCW 32s linear infinite; }
      @keyframes sunSpinCW  { to { transform: rotate(360deg); } }
      @keyframes sunSpinCCW { to { transform: rotate(-360deg); } }
      @media (prefers-reduced-motion: reduce) {
        .sun__long, .sun__short { animation: none; }
      }
      .brand__name { color: var(--ink); font-weight: 500; letter-spacing: 0.22em; }
      .brand__ver { color: var(--muted); }
      .nav { display: flex; gap: clamp(0.6rem, 2vw, 1.6rem); }
      .nav a {
        position: relative; z-index: 0;
        color: var(--muted);
        padding: 0.4em 0.6em;
        transition: color 200ms ease;
      }
      .nav a::before {
        content: ''; position: absolute; inset: 0; z-index: -1;
        background: var(--accent);
        clip-path: inset(0 50% 0 50%);
        transition: clip-path calc(0.5s * (0.4 + var(--m, 0.44))) var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
      }
      .nav a:hover, .nav a:focus-visible { color: var(--bg-light); }
      .nav a:hover::before, .nav a:focus-visible::before { clip-path: inset(0 0 0 0); }
      .topbar__right { display: flex; align-items: center; gap: clamp(1.2rem, 3vw, 2.6rem); }

      /* Mobile disclosure menu (hidden on desktop) */
      .menu { display: none; position: relative; }
      .menu > summary {
        list-style: none; cursor: pointer;
        font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.16em;
        font-size: 0.7rem; color: var(--muted); padding: 0.45rem 0.2rem;
      }
      .menu > summary::-webkit-details-marker { display: none; }
      .menu[open] > summary { color: var(--ink); }
      .menu__panel {
        position: absolute; right: 0; top: 100%; margin-top: 0.55rem;
        display: flex; flex-direction: column; gap: 0.9rem;
        min-width: 160px; padding: 0.95rem 1.1rem; z-index: 30;
        background: var(--bg-light);
        border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
        border-radius: 6px;
      }
      .menu__panel a {
        color: var(--muted); font-family: var(--f-mono); text-transform: uppercase;
        letter-spacing: 0.16em; font-size: 0.72rem; transition: color 160ms ease;
      }
      .menu__panel a:hover { color: var(--ink); }

      /* Page body */
      .page {
  flex: 1;
  width: 100%;
  max-width: 760px;
  margin-inline: auto;
  padding: clamp(1rem, 3vw, 2rem) clamp(1.4rem, 4vw, 2rem) clamp(4rem, 10vw, 7rem);
}

      /* Footer plate */
      .plate {
        display: flex; justify-content: space-between; gap: 1rem;
        padding: clamp(1.2rem, 3vw, 2.2rem) clamp(1.4rem, 4vw, 3.2rem);
        color: var(--muted);
        border-top: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
      }
      .plate span { font-size: 0.68rem; }

      @media (max-width: 720px) {
        .nav { display: none; }
        .menu { display: block; }
        .plate { flex-direction: column; gap: 0.4rem; }
      }
    </style>
  </body>
</html>
