---
interface Props {
  href: string;
  title: string;
  meta?: string;
  description?: string;
  external?: boolean;
}
const { href, title, meta, description, external = false } = Astro.props;
---

<a class="entry-card" href={href}
   target={external ? '_blank' : undefined}
   rel={external ? 'noopener noreferrer' : undefined}>
  {meta && <span class="entry-card__meta eyebrow">{meta}</span>}
  <h3 class="entry-card__title">
    {title}
    <svg class="entry-card__arrow" viewBox="0 0 16 16" aria-hidden="true">
      <path d={external ? 'M3 13L13 3M13 3H6M13 3V10' : 'M2 8H14M14 8L9 3M14 8L9 13'}
        stroke="currentColor" stroke-width="1.25" fill="none"
        stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </h3>
  {description && <p class="entry-card__desc">{description}</p>}
</a>

<style>
  .entry-card {
    display: block;
    padding: var(--s-5) 0;
    border-top: 1px solid var(--c-rule);
    color: var(--c-ink);
    text-decoration: none;
    transition: padding-left var(--dur-fast) var(--ease-out);
  }
  .entry-card:last-of-type { border-bottom: 1px solid var(--c-rule); }
  .entry-card:hover { padding-left: var(--s-3); }
  .entry-card:hover .entry-card__arrow { transform: translateX(3px); color: var(--c-bark-deep); }

  .entry-card__meta { color: var(--c-ink-mute); margin-bottom: var(--s-2); }
  .entry-card__title {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    font-weight: 400;
    color: var(--c-ink-soft);
    line-height: var(--ld-snug);
    letter-spacing: var(--tr-tight);
    font-variation-settings: 'opsz' 96;
    display: inline-flex;
    align-items: baseline;
    gap: var(--s-3);
    margin: 0;
  }
  .entry-card__arrow {
    width: 0.7em; height: 0.7em;
    color: var(--c-ink-mute);
    transition: transform var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out);
    align-self: center;
  }
  .entry-card__desc {
    margin-top: var(--s-3);
    font-size: var(--t-sm);
    color: var(--c-ink-mute);
    line-height: var(--ld-relaxed);
    max-width: 60ch;
  }
</style>
