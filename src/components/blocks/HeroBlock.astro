---
interface Props {
  eyebrow?: string;
  title: string;
  tagline?: string;
  align?: 'center' | 'left';
  size?: 'display' | 'large' | 'medium';
}

const { eyebrow, title, tagline, align = 'center', size = 'large' } = Astro.props;
---

<section class:list={['block-hero', `is-${align}`, `is-${size}`]} data-pagefind-ignore>
  <div class="container">
    {eyebrow && <p class="block-hero__eyebrow eyebrow">{eyebrow}</p>}
    <h1 class="block-hero__title">{title}</h1>
    {tagline && <p class="block-hero__tagline">{tagline}</p>}
  </div>
</section>

<style>
  .block-hero { padding-block: var(--s-16) var(--s-10); }
  .block-hero.is-display { padding-block: clamp(var(--s-12), 18vh, var(--s-20)) var(--s-8); }
  .block-hero.is-center .container { text-align: center; }

  .block-hero__eyebrow { color: var(--c-ink-mute); margin-bottom: var(--s-5); display: block; }

  .block-hero__title {
    font-family: var(--f-display);
    color: var(--c-ink);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.04em;
    font-variation-settings: 'opsz' 144;
    margin: 0;
  }
  .block-hero.is-display .block-hero__title { font-size: clamp(4rem, 14vw, 9rem); }
  .block-hero.is-large   .block-hero__title { font-size: clamp(var(--t-3xl), 8vw, var(--t-5xl)); line-height: var(--ld-tight); }
  .block-hero.is-medium  .block-hero__title { font-size: clamp(var(--t-2xl), 5vw, var(--t-4xl)); line-height: var(--ld-tight); }

  .block-hero__tagline {
    margin-top: var(--s-5);
    font-family: var(--f-display);
    font-style: italic;
    font-size: clamp(var(--t-md), 2.2vw, var(--t-lg));
    color: var(--c-ink-mute);
    font-weight: 300;
    letter-spacing: var(--tr-snug);
    max-width: 36ch;
    font-variation-settings: 'opsz' 96;
  }
  .block-hero.is-center .block-hero__tagline { margin-inline: auto; }
</style>
