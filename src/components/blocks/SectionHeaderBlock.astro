---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<header class:list={['block-section-header', `is-${align}`]}>
  <div class="container container--narrow">
    {eyebrow && <p class="block-section-header__eyebrow eyebrow">{eyebrow}</p>}
    <h1 class="block-section-header__title">{title}</h1>
    {description && <p class="block-section-header__desc">{description}</p>}
  </div>
</header>

<style>
  .block-section-header { padding-block: var(--s-12) var(--s-8); }
  .block-section-header.is-center .container { text-align: center; }

  .block-section-header__eyebrow {
    color: var(--c-bark-deep);
    margin-bottom: var(--s-5);
    display: block;
  }
  .block-section-header__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-3xl), 6vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 144;
    margin: 0;
  }
  .block-section-header__desc {
    margin-top: var(--s-5);
    font-size: var(--t-md);
    line-height: var(--ld-relaxed);
    color: var(--c-ink-mute);
    max-width: 50ch;
  }
  .block-section-header.is-center .block-section-header__desc { margin-inline: auto; }
</style>
