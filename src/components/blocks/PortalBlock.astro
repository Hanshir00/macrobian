---
interface Tile {
  label: string;
  description?: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  tiles: Tile[];
}

const { eyebrow, tiles } = Astro.props;
---

<section class="block-portal" data-pagefind-ignore>
  <div class="container container--narrow">
    {eyebrow && <p class="block-portal__eyebrow eyebrow">{eyebrow}</p>}
    <div class="block-portal__grid" role="navigation" aria-label="Sections">
      {tiles.map((tile, i) => (
        <a class="portal" href={tile.href} style={`--i: ${i}`}>
          <span class="portal__index" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="portal__label">{tile.label}</span>
          {tile.description && <span class="portal__desc">{tile.description}</span>}
          <span class="portal__cue" aria-hidden="true">
            <svg viewBox="0 0 32 32">
              <path d="M6 16h20M20 8l8 8-8 8"
                stroke="currentColor" stroke-width="1.25"
                fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .block-portal { padding-block: var(--s-8); }
  .block-portal__eyebrow {
    text-align: center;
    margin-bottom: var(--s-6);
    color: var(--c-bark-deep);
    display: block;
  }

  .block-portal__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-4);
  }
  @media (min-width: 720px) {
    .block-portal__grid {
      grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
      gap: var(--s-5);
    }
  }

  .portal {
    --portal-pad: var(--s-8);
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    grid-template-areas:
      "index label cue"
      "index desc  cue";
    column-gap: var(--s-5);
    row-gap: var(--s-2);
    align-items: center;
    padding: var(--portal-pad);
    background: var(--c-paper-deep);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-md);
    color: var(--c-ink);
    text-decoration: none;
    overflow: hidden;
    isolation: isolate;
    transition:
      transform var(--dur-med) var(--ease-out),
      border-color var(--dur-med) var(--ease-out),
      box-shadow var(--dur-med) var(--ease-out);
  }

  .portal::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 80% at 100% 100%, color-mix(in srgb, var(--c-moss) 12%, transparent), transparent 60%);
    z-index: -1;
    opacity: 0;
    transition: opacity var(--dur-med) var(--ease-out);
  }

  .portal:hover {
    transform: translateY(-2px);
    border-color: var(--c-moss-deep);
    box-shadow: var(--shadow-lg);
  }
  .portal:hover::before { opacity: 1; }

  .portal__index {
    grid-area: index;
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--t-md);
    color: var(--c-ink-mute);
    font-weight: 300;
    align-self: start;
    padding-top: 0.4em;
  }

  .portal__label {
    grid-area: label;
    font-family: var(--f-display);
    font-size: clamp(var(--t-2xl), 4.5vw, var(--t-3xl));
    line-height: 1;
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-weight: 400;
    font-variation-settings: 'opsz' 144;
  }

  .portal__desc {
    grid-area: desc;
    font-size: var(--t-sm);
    color: var(--c-ink-mute);
    line-height: var(--ld-snug);
    max-width: 32ch;
  }

  .portal__cue {
    grid-area: cue;
    width: 1.75rem;
    height: 1.75rem;
    color: var(--c-ink-mute);
    transition: transform var(--dur-med) var(--ease-out),
                color var(--dur-med) var(--ease-out);
  }
  .portal:hover .portal__cue { transform: translateX(4px); color: var(--c-moss-deep); }
  .portal__cue svg { width: 100%; height: 100%; }
</style>
