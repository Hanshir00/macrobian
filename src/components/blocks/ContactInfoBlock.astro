---
interface Social { platform: string; url: string; }
interface Props {
  emailLabel?: string;
  email: string;
  socialsLabel?: string;
  socials?: Social[];
}
const { emailLabel = 'Email', email, socialsLabel = 'Elsewhere', socials = [] } = Astro.props;
const activeSocials = socials.filter((s) => s.url);
---

<section class="block-contact">
  <div class="container container--narrow">
    <div class="block-contact__row">
      <span class="eyebrow block-contact__label">{emailLabel}</span>
      <a href={`mailto:${email}`} class="block-contact__value">{email}</a>
    </div>

    {activeSocials.length > 0 && (
      <div class="block-contact__row">
        <span class="eyebrow block-contact__label">{socialsLabel}</span>
        <ul class="block-contact__socials">
          {activeSocials.map((s) => (
            <li>
              <a href={s.url} target="_blank" rel="noopener noreferrer">{s.platform}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>

<style>
  .block-contact { padding-block: var(--s-4); }
  .block-contact__row {
    display: grid;
    gap: var(--s-3);
    padding-block: var(--s-6);
    border-top: 1px solid var(--c-rule);
  }
  .block-contact__row:last-child { border-bottom: 1px solid var(--c-rule); }

  .block-contact__label { color: var(--c-bark-deep); }
  .block-contact__value {
    font-family: var(--f-display);
    font-size: clamp(var(--t-xl), 4vw, var(--t-3xl));
    color: var(--c-ink-soft);
    letter-spacing: var(--tr-tight);
    font-variation-settings: 'opsz' 144;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
    word-break: break-word;
  }
  .block-contact__value:hover { color: var(--c-bark-deep); }

  .block-contact__socials {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }
  .block-contact__socials a {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    color: var(--c-ink-soft);
    text-decoration: none;
    text-transform: capitalize;
    letter-spacing: var(--tr-tight);
    font-variation-settings: 'opsz' 96;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .block-contact__socials a:hover { color: var(--c-bark-deep); }
</style>
