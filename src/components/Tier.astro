---
interface Props {
  name?: string;
  price?: string;
  tagline?: string;
  features?: string;       // pipe-separated list: "Bottle of serum|30-min consult|Peptide guide"
  href?: string;           // Stripe Payment Link
  cta?: string;
  featured?: boolean;
}
const { name, price, tagline, features, href = '#', cta = 'Get started', featured } = Astro.props;
const featureList = (features || '').split('|').map((f) => f.trim()).filter(Boolean);
---

<div class:list={["tier", featured && "tier--featured"]}>
  {featured && <span class="tier__flag">Most popular</span>}
  <span class="tier__name">{name}</span>
  <span class="tier__price">{price}</span>
  {tagline && <p class="tier__tagline">{tagline}</p>}
  {featureList.length > 0 && (
    <ul class="tier__features">
      {featureList.map((f) => (
        <li><span class="tier__tick" aria-hidden="true">+</span>{f}</li>
      ))}
    </ul>
  )}
  <a class="tier__cta" href={href} target="_blank" rel="noopener">
    {cta} <span aria-hidden="true">&rarr;</span>
  </a>
</div>

<style>
  .tier {
    position: relative;
    display: flex; flex-direction: column;
    padding: 2rem 1.8rem;
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg-light) 60%, transparent);
  }
  .tier--featured {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }
  .tier__flag {
    position: absolute; top: -0.7rem; left: 1.8rem;
    background: var(--accent); color: #fff;
    font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.1em;
    font-size: 0.62rem; padding: 0.28rem 0.6rem; border-radius: 4px;
  }
  .tier__name {
    font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.16em;
    font-size: 0.78rem; color: var(--muted);
  }
  .tier__price {
    font-family: var(--f-display); font-weight: 700;
    font-size: 2.6rem; color: var(--ink); margin: 0.3rem 0 0;
  }
  .tier__tagline { color: color-mix(in srgb, var(--ink) 70%, var(--bg-dark)); margin: 0.4rem 0 1.2rem; line-height: 1.5; }
  .tier__features { list-style: none; padding: 0; margin: 0 0 1.6rem; display: flex; flex-direction: column; gap: 0.7rem; }
  .tier__features li {
    display: flex; gap: 0.6rem; align-items: flex-start;
    font-size: 0.98rem; line-height: 1.4;
    color: color-mix(in srgb, var(--ink) 82%, var(--bg-dark));
  }
  .tier__tick { color: var(--accent); font-weight: 700; flex: none; }
  .tier__cta {
    margin-top: auto;
    display: inline-flex; align-items: center; justify-content: center; gap: 0.7rem;
    background: var(--ink); color: var(--bg-light);
    font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.12em;
    font-size: 0.78rem; padding: 0.95rem 1.3rem; border-radius: 7px;
    text-decoration: none; transition: opacity 0.18s;
  }
  .tier--featured .tier__cta { background: var(--accent); color: #fff; }
  .tier__cta:hover { opacity: 0.88; }
</style>
