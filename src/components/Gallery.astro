---
/**
 * Product/entry image gallery.
 * Large main image with a clickable thumbnail strip. Images stay full colour;
 * on hover an accent sweep irises open from the cursor (Aperture, accent variant).
 * No library — a tiny per-instance script.
 */
interface Props { images?: string[]; alt?: string; }
const { images, alt = '' } = Astro.props;
// Keystatic's image field stores a bare filename (e.g. "serum.png"); resolve it
// to its public path. Absolute paths (starting with /) are left untouched.
const resolve = (s: string) =>
  s.startsWith('/') || s.startsWith('http') ? s : `/images/gallery/${s}`;
const imgs = (images || []).filter(Boolean).map(resolve);
const uid = 'gal-' + Math.random().toString(36).slice(2, 9);
---

{imgs.length > 0 && (
  <figure class="gallery" id={uid}>
    <div class="gallery__main" data-sweep>
      <img src={imgs[0]} alt={alt} data-main />
      <span class="gallery__sweep" aria-hidden="true"></span>
    </div>
    {imgs.length > 1 && (
      <div class="gallery__thumbs">
        {imgs.map((src, i) => (
          <button
            class="gallery__thumb"
            type="button"
            data-src={src}
            aria-label={`Show image ${i + 1}`}
            aria-current={i === 0 ? 'true' : 'false'}
          >
            <img src={src} alt="" loading="lazy" />
          </button>
        ))}
      </div>
    )}
  </figure>
)}

<script define:vars={{ uid }}>
  (() => {
    const root = document.getElementById(uid);
    if (!root) return;
    const main = root.querySelector('[data-main]');
    const thumbs = root.querySelectorAll('.gallery__thumb');
    thumbs.forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-src');
        if (src && main) main.setAttribute('src', src);
        thumbs.forEach((b) => b.setAttribute('aria-current', b === btn ? 'true' : 'false'));
      });
    });
    // Aperture sweep follows the cursor over the main image.
    const box = root.querySelector('[data-sweep]');
    if (box) {
      const setPt = (e) => {
        const r = box.getBoundingClientRect();
        const px = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
        const py = Math.max(0, Math.min(1, (e.clientY - r.top) / r.height));
        box.style.setProperty('--x', (px * 100).toFixed(1) + '%');
        box.style.setProperty('--y', (py * 100).toFixed(1) + '%');
      };
      box.addEventListener('pointerenter', (e) => { if (e.pointerType === 'mouse') setPt(e); });
      box.addEventListener('pointermove', (e) => { if (e.pointerType === 'mouse') setPt(e); });
    }
  })();
</script>

<style>
  .gallery { margin: 0 0 2.4rem; }
  .gallery__main {
    position: relative;
    border: 1px solid color-mix(in srgb, var(--muted) 25%, transparent);
    border-radius: 8px; overflow: hidden; background: var(--bg-light);
  }
  .gallery__main img { display: block; width: 100%; height: auto; }

  /* Aperture (accent sweep): image stays full colour; an accent tint irises
     open from the cursor point on hover. */
  .gallery__sweep {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: color-mix(in srgb, var(--accent) 24%, transparent);
    mix-blend-mode: multiply;
    --ap: 0%;
    clip-path: polygon(
      calc(var(--x, 50%) - var(--ap)) calc(var(--y, 50%) - var(--ap)),
      calc(var(--x, 50%) + var(--ap)) calc(var(--y, 50%) - var(--ap)),
      calc(var(--x, 50%) + var(--ap)) calc(var(--y, 50%) + var(--ap)),
      calc(var(--x, 50%) - var(--ap)) calc(var(--y, 50%) + var(--ap))
    );
    transition: --ap calc(0.62s * (0.4 + var(--m, 0.44))) var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .gallery__main:hover .gallery__sweep { --ap: 170%; }

  .gallery__thumbs { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.6rem; }
  .gallery__thumb {
    width: 64px; height: 64px; padding: 0; cursor: pointer;
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    border-radius: 5px; overflow: hidden; background: none;
    transition: border-color 160ms ease;
  }
  .gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .gallery__thumb[aria-current='true'] { border-color: var(--accent); }
  .gallery__thumb:hover { border-color: var(--ink); }
</style>
