---
interface Props { title?: string; }
const { title = 'Caution' } = Astro.props;
---

<aside class="warning" role="note">
  <p class="warning__title">
    <svg viewBox="0 0 16 16" aria-hidden="true" class="warning__icon">
      <path d="M8 1L15 14H1L8 1Z" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round" />
      <line x1="8" y1="6" x2="8" y2="10" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
      <circle cx="8" cy="12" r="0.6" fill="currentColor" />
    </svg>
    {title}
  </p>
  <div class="warning__body">
    <slot />
  </div>
</aside>

<style>
  .warning {
    margin: var(--s-6) 0;
    padding: var(--s-5);
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, #9a6a1e 40%, var(--c-rule) 60%);
    background: color-mix(in srgb, #c8941f 12%, var(--c-paper) 88%);
  }
  .warning__title {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    font-family: var(--f-body);
    font-size: var(--t-xs);
    font-weight: 600;
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: #7a4e12;
    margin: 0 0 var(--s-2) 0;
  }
  .warning__icon { width: 14px; height: 14px; flex-shrink: 0; }
  .warning__body :global(p:last-child) { margin-bottom: 0; }
  .warning__body :global(p) { font-size: var(--t-sm); line-height: var(--ld-relaxed); color: var(--c-ink-soft); }
</style>
