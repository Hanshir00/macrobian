---
interface Props {
  tone?: 'info' | 'tip' | 'warning';
  title?: string;
}
const { tone = 'info', title } = Astro.props;
---

<aside class:list={['callout', `callout--${tone}`]}>
  {title && <p class="callout__title">{title}</p>}
  <div class="callout__body"><slot /></div>
</aside>

<style>
  .callout {
    margin: 1.6rem 0;
    padding: 1.1rem 1.2rem 1rem;
    border-inline-start: 2px solid var(--ink);
    background: color-mix(in srgb, var(--muted) 10%, transparent);
    border-radius: 0 4px 4px 0;
  }
  .callout--tip     { border-inline-start-color: var(--accent); background: color-mix(in srgb, var(--accent) 6%, transparent); }
  .callout--warning { border-inline-start-color: #b8651f;       background: color-mix(in srgb, #c8941f 10%, transparent); }

  .callout__title {
    font-family: var(--f-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink);
    margin: 0 0 0.5rem 0;
  }
  .callout__body :global(p:last-child) { margin-bottom: 0; }
  .callout__body :global(p) { font-size: 1rem; line-height: 1.6; margin: 0 0 0.6rem; }
</style>
