---
interface Props {
  amount?: string;
  frequency?: string;
  route?: string;
  notes?: string;
}
const { amount, frequency, route, notes } = Astro.props;
const rows = [
  { label: 'Amount',    value: amount },
  { label: 'Frequency', value: frequency },
  { label: 'Route',     value: route },
  { label: 'Notes',     value: notes },
].filter((r) => r.value);
---

<div class="dosage">
  <p class="dosage__heading">Dosage</p>
  <dl class="dosage__grid">
    {rows.map((r) => (
      <div class="dosage__row">
        <dt>{r.label}</dt>
        <dd>{r.value}</dd>
      </div>
    ))}
  </dl>
</div>

<style>
  .dosage {
    margin: var(--s-6) 0;
    padding: var(--s-5);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-md);
    background: var(--c-paper-deep);
  }
  .dosage__heading {
    font-family: var(--f-body);
    font-size: var(--t-xs);
    font-weight: 600;
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-bark-deep);
    margin: 0 0 var(--s-3) 0;
  }
  .dosage__grid { margin: 0; display: grid; gap: var(--s-2); }
  .dosage__row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--s-3);
    padding-block: var(--s-2);
    border-top: 1px solid var(--c-rule-soft);
  }
  .dosage__row:first-child { border-top: 0; }
  .dosage__row dt {
    font-size: var(--t-xs);
    letter-spacing: var(--tr-wide);
    text-transform: uppercase;
    color: var(--c-ink-mute);
  }
  .dosage__row dd { margin: 0; font-size: var(--t-sm); color: var(--c-ink-soft); }
  @media (max-width: 480px) {
    .dosage__row { grid-template-columns: 1fr; gap: var(--s-1); }
  }
</style>
