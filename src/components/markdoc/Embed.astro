---
/**
 * Interactive tool embed.
 * Renders a self-contained .html file (e.g. a calculator built in Claude
 * Design, dropped into /public/tools/) inside a responsive iframe.
 *
 * Height auto-sizes to the tool's content. Because the tool is served from
 * your own domain, the iframe is same-origin, so the parent can measure the
 * content directly — you DON'T need to add any script to the tool itself.
 * Just upload the .html and point `src` at it.
 */
interface Props { src?: string; title?: string; minHeight?: number; }
const { src, title = 'Interactive tool', minHeight = 320 } = Astro.props;
const hasSrc = !!(src && src.trim());
const uid = 'tool-' + Math.random().toString(36).slice(2, 9);
---

{hasSrc ? (
  <div class="tool">
    <iframe
      id={uid}
      src={src}
      title={title}
      loading="lazy"
      scrolling="no"
      style={`min-height:${minHeight}px`}
    ></iframe>
  </div>
) : (
  <p class="tool__missing">
    Interactive tool — set the source path (e.g. <code>/tools/your-tool/</code>).
  </p>
)}

<script define:vars={{ uid, minHeight }}>
  (() => {
    const iframe = document.getElementById(uid);
    if (!iframe) return;
    const resize = () => {
      try {
        const doc = iframe.contentDocument || iframe.contentWindow.document;
        if (!doc) return;
        const h = Math.max(
          doc.documentElement.scrollHeight,
          doc.body ? doc.body.scrollHeight : 0,
          minHeight,
        );
        iframe.style.height = h + 'px';
      } catch (e) {
        /* cross-origin tools can't be measured — they keep the min height.
           First-party tools under /public are same-origin, so this is fine. */
      }
    };
    iframe.addEventListener('load', () => {
      resize();
      try {
        const doc = iframe.contentDocument;
        if (doc) {
          const ro = new ResizeObserver(resize);
          ro.observe(doc.documentElement);
          if (doc.body) ro.observe(doc.body);
        }
      } catch (e) {}
    });
    window.addEventListener('resize', resize);
  })();
</script>

<style>
  .tool {
    margin: 1.8rem 0;
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-light);
  }
  .tool iframe { display: block; width: 100%; border: 0; }
  .tool__missing {
    margin: 1.8rem 0;
    padding: 1rem 1.2rem;
    border: 1px dashed color-mix(in srgb, var(--muted) 50%, transparent);
    border-radius: 8px;
    font-family: var(--f-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }
</style>
