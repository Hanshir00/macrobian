---
interface Props {
  authors?: string;
  title?: string;
  source?: string;
  year?: string;
  url?: string;
}
const { authors, title, source, year, url } = Astro.props;
const meta = [source, year].filter(Boolean).join(', ');
---

<cite class="citation">
  <span class="citation__mark" aria-hidden="true">§</span>
  <span class="citation__text">
    {authors && <span class="citation__authors">{authors}. </span>}
    {title && (
      url
        ? <a class="citation__title" href={url} target="_blank" rel="noopener noreferrer">{title}</a>
        : <span class="citation__title">{title}</span>
    )}
    {meta && <span class="citation__meta"> — {meta}</span>}
  </span>
</cite>

<style>
  .citation {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--s-3);
    margin: var(--s-5) 0;
    padding: var(--s-3) var(--s-4);
    border-inline-start: 2px solid var(--c-rule);
    font-style: normal;
    background: color-mix(in srgb, var(--c-paper-deep) 60%, var(--c-paper) 40%);
  }
  .citation__mark {
    font-family: var(--f-display);
    color: var(--c-bark-deep);
    font-size: var(--t-md);
    line-height: 1.4;
  }
  .citation__text { font-size: var(--t-sm); line-height: var(--ld-relaxed); color: var(--c-ink-soft); }
  .citation__authors { color: var(--c-ink-mute); }
  .citation__title { font-style: italic; color: var(--c-ink-soft); }
  a.citation__title { text-decoration: underline; text-decoration-color: var(--c-rule); text-underline-offset: 0.15em; }
  a.citation__title:hover { text-decoration-color: currentColor; }
  .citation__meta { color: var(--c-ink-mute); }
</style>
