---
interface Props { authors?: string; title?: string; source?: string; year?: string; url?: string; }
const { authors, title, source, year, url } = Astro.props;
const meta = [source, year].filter(Boolean).join(', ');
---

<cite class="cite">
  <span class="cite__mark" aria-hidden="true">§</span>
  <span class="cite__text">
    {authors && <span class="cite__authors">{authors}. </span>}
    {title && (
      url
        ? <a class="cite__title" href={url} target="_blank" rel="noopener noreferrer">{title}</a>
        : <span class="cite__title">{title}</span>
    )}
    {meta && <span class="cite__meta"> — {meta}</span>}
  </span>
</cite>

<style>
  .cite {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.7rem;
    margin: 1.4rem 0;
    padding: 0.7rem 0.9rem;
    border-inline-start: 2px solid color-mix(in srgb, var(--muted) 60%, transparent);
    background: color-mix(in srgb, var(--muted) 8%, transparent);
    font-style: normal;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .cite__mark {
    font-family: var(--f-display);
    font-weight: 700;
    color: var(--accent);
    font-size: 1.1rem;
    line-height: 1.4;
  }
  .cite__text { color: color-mix(in srgb, var(--ink) 85%, var(--bg-dark)); }
  .cite__authors { color: var(--muted); }
  .cite__title { font-style: italic; }
  a.cite__title { color: var(--ink); text-decoration: underline; text-decoration-color: var(--muted); text-underline-offset: 0.15em; }
  a.cite__title:hover { text-decoration-color: var(--accent); color: var(--accent); }
  .cite__meta { color: var(--muted); }
</style>
