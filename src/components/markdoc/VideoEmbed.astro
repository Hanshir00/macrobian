---
interface Props { url?: string; title?: string; }
const { url, title = 'Video' } = Astro.props;

/** Parse a YouTube or Vimeo URL into an embeddable src. */
function toEmbed(raw: string): { src: string; provider: 'youtube' | 'vimeo' | 'other' } | null {
  if (!raw || !raw.trim()) return null;
  let u: URL;
  try { u = new URL(raw); } catch { return null; }
  const host = u.hostname.replace(/^www\./, '');

  // YouTube — watch?v=, youtu.be/, embed/, shorts/
  if (host === 'youtube.com' || host === 'm.youtube.com') {
    const v = u.searchParams.get('v');
    if (v) return { src: `https://www.youtube.com/embed/${v}`, provider: 'youtube' };
    const m = u.pathname.match(/^\/(embed|shorts)\/([\w-]+)/);
    if (m) return { src: `https://www.youtube.com/embed/${m[2]}`, provider: 'youtube' };
  }
  if (host === 'youtu.be') {
    const id = u.pathname.slice(1);
    if (id) return { src: `https://www.youtube.com/embed/${id}`, provider: 'youtube' };
  }

  // Vimeo
  if (host === 'vimeo.com' || host === 'player.vimeo.com') {
    const m = u.pathname.match(/(\d+)/);
    if (m) return { src: `https://player.vimeo.com/video/${m[1]}`, provider: 'vimeo' };
  }

  // Fallback: pass through if the URL already looks like an embed
  if (raw.includes('/embed/') || raw.includes('player.')) return { src: raw, provider: 'other' };
  return null;
}

const parsed = url ? toEmbed(url) : null;
---

{parsed ? (
  <figure class="video">
    <div class="video__frame">
      <iframe
        src={parsed.src}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
    {title && title !== 'Video' && <figcaption class="video__cap">{title}</figcaption>}
  </figure>
) : url ? (
  <p class="video-fallback">
    Video: <a href={url} target="_blank" rel="noopener noreferrer">{url}</a>
  </p>
) : null}

<style>
  .video { margin: 2rem 0; padding: 0; border: 0; }
  .video__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--ink);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--muted) 30%, transparent);
  }
  .video__frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .video__cap {
    margin-top: 0.7rem;
    font-family: var(--f-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  .video-fallback {
    margin: 1.4rem 0;
    font-family: var(--f-mono);
    font-size: 0.85rem;
    color: var(--muted);
  }
  .video-fallback a { color: var(--accent); }
</style>
