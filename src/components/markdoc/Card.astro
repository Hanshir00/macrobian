---
interface Props { title?: string; description?: string; href?: string; }
const { title, description, href } = Astro.props;
const safeTitle = (title && title.trim()) || 'Untitled';
const hasLink = !!(href && href.trim());
const isExternal = hasLink && /^https?:\/\//i.test(href!);
const Tag = hasLink ? 'a' : 'div';
const linkAttrs = hasLink
  ? (isExternal ? { href, target: '_blank', rel: 'noopener noreferrer' } : { href })
  : {};
---

<Tag class="card" data-bloom {...linkAttrs}>
  <span class="card__bloom" aria-hidden="true"></span>
  <span class="card__title">{safeTitle}</span>
  {description && <span class="card__desc">{description}</span>}
  {hasLink && <span class="card__cue" aria-hidden="true">→</span>}
</Tag>

<style>
  .card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 0.45rem;
    padding: 1rem 1.1rem 0.9rem;
    background: color-mix(in srgb, var(--muted) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
    border-radius: 4px;
    transition: border-color 160ms ease, transform 160ms ease;
    color: var(--ink);
    text-decoration: none;
  }
  .card:hover { border-color: var(--accent); transform: translateY(-1px); }

  /* Aperture, adapted for text cards: an accent wash irises open from the
     cursor point, behind the text (text stays readable). */
  .card__bloom {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    --ap: 0%;
    clip-path: polygon(
      calc(var(--x, 50%) - var(--ap)) calc(var(--y, 50%) - var(--ap)),
      calc(var(--x, 50%) + var(--ap)) calc(var(--y, 50%) - var(--ap)),
      calc(var(--x, 50%) + var(--ap)) calc(var(--y, 50%) + var(--ap)),
      calc(var(--x, 50%) - var(--ap)) calc(var(--y, 50%) + var(--ap))
    );
    transition: --ap calc(0.6s * (0.4 + var(--m, 0.44))) var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }
  .card:hover .card__bloom,
  .card:focus-visible .card__bloom { --ap: 175%; }

  .card__title, .card__desc, .card__cue { position: relative; z-index: 1; }
  .card__title { font-family: var(--f-display); font-weight: 600; font-size: 1.02rem; color: var(--ink); }
  .card__desc { font-size: 0.88rem; line-height: 1.45; color: color-mix(in srgb, var(--ink) 70%, var(--bg-dark)); }
  .card__cue {
    align-self: end; justify-self: end;
    font-family: var(--f-mono); font-size: 0.8rem; color: var(--muted);
    transition: color 160ms ease, transform 160ms ease;
  }
  .card:hover .card__cue { color: var(--accent); transform: translateX(2px); }
</style>

<script>
  document.querySelectorAll('.card[data-bloom]').forEach((card) => {
    if (card.dataset.bloomBound) return;
    card.dataset.bloomBound = '1';
    const setPt = (e) => {
      const r = card.getBoundingClientRect();
      const px = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
      const py = Math.max(0, Math.min(1, (e.clientY - r.top) / r.height));
      card.style.setProperty('--x', (px * 100).toFixed(1) + '%');
      card.style.setProperty('--y', (py * 100).toFixed(1) + '%');
    };
    card.addEventListener('pointerenter', (e) => { if (e.pointerType === 'mouse') setPt(e); });
    card.addEventListener('pointermove', (e) => { if (e.pointerType === 'mouse') setPt(e); });
  });
</script>
