---
interface Props {
  href?: string;        // Stripe Payment Link URL (buy.stripe.com/...)
  label?: string;       // button text, e.g. "Buy the serum — $XX"
  color?: string;       // "ink" (default, dark) | "accent" (red) | "outline"
  size?: string;        // "sm" | "md" (default) | "lg"
  align?: string;       // "left" | "center" (default)
}
const {
  href = '#',
  label = 'Buy now',
  color = 'ink',
  size = 'md',
  align = 'center',
} = Astro.props;
---

<div class:list={["buybtn-wrap", `buybtn-wrap--${align}`]}>
  <a
    class:list={["buybtn", `buybtn--${color}`, `buybtn--${size}`]}
    href={href}
    target="_blank"
    rel="noopener"
  >
    {label} <span class="buybtn__arrow" aria-hidden="true">&rarr;</span>
  </a>
</div>

<style>
  .buybtn-wrap { margin: 2rem 0; display: flex; }
  .buybtn-wrap--center { justify-content: center; }
  .buybtn-wrap--left { justify-content: flex-start; }

  .buybtn {
    /* ---- TWEAKABLE: base button look ---- */
    display: inline-flex; align-items: center; gap: 0.7rem;
    font-family: var(--f-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    border-radius: 7px;
    transition: opacity 0.18s, background 0.18s, color 0.18s;
    cursor: pointer;
  }
  .buybtn:hover { opacity: 0.88; }
  .buybtn__arrow { transition: transform 0.18s; }
  .buybtn:hover .buybtn__arrow { transform: translateX(3px); }

  /* ---- TWEAKABLE: colors ---- */
  .buybtn--ink     { background: var(--ink); color: var(--bg-light); }
  .buybtn--accent  { background: var(--accent); color: #fff !important; }
  .buybtn--accent .buybtn__arrow { color: #fff; }
  .buybtn--outline {
    background: transparent; color: var(--ink);
    border: 1px solid color-mix(in srgb, var(--ink) 45%, transparent);
  }
  .buybtn--outline:hover { background: var(--ink); color: var(--bg-light); }

  /* ---- TWEAKABLE: sizes ---- */
  .buybtn--sm { font-size: 0.72rem; padding: 0.7rem 1.1rem; }
  .buybtn--md { font-size: 0.8rem;  padding: 0.95rem 1.4rem; }
  .buybtn--lg { font-size: 0.92rem; padding: 1.15rem 1.9rem; }
</style>
