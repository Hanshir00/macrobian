---
interface Props { attribution?: string; }
const { attribution } = Astro.props;
---

<figure class="pq">
  <blockquote class="pq__quote"><slot /></blockquote>
  {attribution && <figcaption class="pq__attr">— {attribution}</figcaption>}
</figure>

<style>
  .pq { margin: 2.2rem 0; padding: 0; border: 0; }
  .pq__quote {
    margin: 0;
    font-family: var(--f-display);
    font-weight: 500;
    font-size: clamp(1.25rem, 2.4vw, 1.65rem);
    line-height: 1.35;
    color: var(--ink);
    padding-inline-start: 1.2rem;
    border-inline-start: 2px solid var(--accent);
  }
  .pq__quote :global(p) { margin: 0; }
  .pq__attr {
    margin-top: 0.8rem;
    padding-inline-start: 1.2rem;
    font-family: var(--f-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }
</style>
