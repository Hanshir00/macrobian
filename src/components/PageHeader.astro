---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<header class:list={['page-header', `is-${align}`]}>
  {eyebrow && <span class="eyebrow page-header__eyebrow">{eyebrow}</span>}
  <h1 class="page-header__title">{title}</h1>
  {description && <p class="page-header__desc">{description}</p>}
</header>

<style>
  .page-header {
    padding-block: var(--s-12) var(--s-10);
    max-width: 38rem;
  }

  .page-header.is-center {
    text-align: center;
    margin-inline: auto;
  }

  .page-header__eyebrow {
    color: var(--c-bark-deep);
    margin-bottom: var(--s-5);
  }

  .page-header__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-3xl), 6vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    margin: 0;
  }

  .page-header__desc {
    margin-top: var(--s-5);
    font-size: var(--t-md);
    line-height: var(--ld-relaxed);
    color: var(--c-ink-mute);
    max-width: 50ch;
  }

  .page-header.is-center .page-header__desc {
    margin-inline: auto;
  }
</style>
