---
import type { Block } from '../config/pages';
import HeroBlock from './blocks/HeroBlock.astro';
import PortalBlock from './blocks/PortalBlock.astro';
import SectionHeaderBlock from './blocks/SectionHeaderBlock.astro';
import SectionListBlock from './blocks/SectionListBlock.astro';
import ProseBlock from './blocks/ProseBlock.astro';
import QuoteBlock from './blocks/QuoteBlock.astro';
import ImageBlock from './blocks/ImageBlock.astro';
import DisclaimerBlock from './blocks/DisclaimerBlock.astro';
import ContactInfoBlock from './blocks/ContactInfoBlock.astro';
import SpacerBlock from './blocks/SpacerBlock.astro';
import FootnoteBlock from './blocks/FootnoteBlock.astro';

interface Props { blocks: Block[]; }
const { blocks = [] } = Astro.props;
---

{blocks.map((block) => {
  switch (block.discriminant) {
    case 'hero':          return <HeroBlock          {...block.value} />;
    case 'portal':        return <PortalBlock        {...block.value} />;
    case 'sectionHeader': return <SectionHeaderBlock {...block.value} />;
    case 'sectionList':   return <SectionListBlock   {...block.value} />;
    case 'prose':         return <ProseBlock         {...block.value} />;
    case 'quote':         return <QuoteBlock         {...block.value} />;
    case 'image':         return <ImageBlock         {...block.value} />;
    case 'disclaimer':    return <DisclaimerBlock    {...block.value} />;
    case 'contactInfo':   return <ContactInfoBlock   {...block.value} />;
    case 'spacer':        return <SpacerBlock        {...block.value} />;
    case 'footnote':      return <FootnoteBlock      {...block.value} />;
    default:              return null;
  }
})}
