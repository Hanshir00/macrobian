---
/**
 * PeptideCalculator.astro
 * Embeds the self-contained peptide calculator (served from /public) in an
 * auto-resizing iframe. No dependencies, no client framework required.
 *
 * Usage:
 *   import PeptideCalculator from "../components/PeptideCalculator.astro";
 *   <PeptideCalculator />
 *
 * Props:
 *   src   – path to the calculator html (default: "/peptide-calculator/index.html")
 *   title – iframe accessible title
 *   maxWidth – CSS max-width of the embed (default: "480px")
 */
const {
  src = "/peptide-calculator/index.html",
  title = "Peptide reconstitution calculator",
  maxWidth = "480px",
} = Astro.props;
---

<div class="peptide-calc" style={`max-width:${maxWidth}`}>
  <iframe src={src} title={title} loading="lazy" scrolling="no" height="780"></iframe>
</div>

<style>
  .peptide-calc { margin-inline: auto; width: 100%; }
  .peptide-calc iframe {
    width: 100%;
    border: 0;
    display: block;
    border-radius: 18px;
    /* falls back to a sensible height before the height message arrives */
  }
</style>

<script>
  // Auto-resize each calculator iframe to its content height.
  window.addEventListener("message", (e) => {
    if (!e.data || e.data.type !== "peptide-calc-height") return;
    document.querySelectorAll(".peptide-calc iframe").forEach((frame) => {
      if (frame.contentWindow === e.source) {
        frame.style.height = e.data.height + "px";
      }
    });
  });
</script>
