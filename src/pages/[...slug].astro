---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  // Every collection publishes at the root (/<slug>), exactly like Pages.
  // List them here; each is independent — this only gathers their entries.
  const collectionNames = [
    'pages', 'pharmacopeia', 'references', 'ilm',
    'links', 'tools', 'drafts', 'other',
  ];

  const seen = new Map(); // slug -> collection it came from
  const paths = [];

  for (const name of collectionNames) {
    // A collection with no entries yet can throw — treat that as empty so the
    // build never breaks just because a collection hasn't been written to.
    let entries = [];
    try {
      entries = await getCollection(name);
    } catch {
      entries = [];
    }
    for (const entry of entries) {
      const slug = entry.id;
      if (seen.has(slug)) {
        throw new Error(
          `Slug clash: "${slug}" exists in both "${seen.get(slug)}" and "${name}". ` +
          `Root URLs require every slug to be unique across all collections — rename one of them.`,
        );
      }
      seen.set(slug, name);
      paths.push({ params: { slug }, props: { entry } });
    }
  }

  return paths;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.intro}>
  <article>
    <a class="back" href="/">&larr; Index</a>
    <header class="page-head">
      <span class="page-head__sq" aria-hidden="true"></span>
      <h1>{entry.data.title}</h1>
      {entry.data.intro && <p class="page-head__intro">{entry.data.intro}</p>}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .back {
      font-family: var(--f-mono);
      text-transform: uppercase;
      letter-spacing: 0.16em;
      font-size: 0.7rem;
      color: var(--muted);
      transition: color 160ms ease;
    }
    .back:hover { color: var(--ink); }

    .page-head { margin: 2.4rem 0 2.6rem; }
    .page-head__sq {
      display: inline-block; width: 11px; height: 11px;
      background: var(--accent); margin-bottom: 1.4rem;
    }
    .page-head h1 {
      font-family: var(--f-display);
      font-weight: 700;
      font-size: clamp(2.4rem, 6vw, 4.4rem);
      line-height: 1.0;
      letter-spacing: -0.03em;
      color: var(--ink);
    }
    .page-head__intro {
      margin-top: 1.2rem;
      font-family: var(--f-display);
      font-size: clamp(1.05rem, 2vw, 1.4rem);
      line-height: 1.4;
      color: color-mix(in srgb, var(--ink) 70%, var(--bg-dark));
      max-width: 50ch;
    }

    /* Rendered markdoc body */
    .prose { font-family: var(--f-display); color: var(--ink); }
    .prose :global(h2) {
      font-family: var(--f-display); font-weight: 700;
      font-size: clamp(1.5rem, 3vw, 2rem); letter-spacing: -0.02em;
      margin: 2.6rem 0 0.9rem; line-height: 1.15;
    }
    .prose :global(h3) {
      font-family: var(--f-display); font-weight: 600;
      font-size: 1.25rem; margin: 2rem 0 0.7rem;
    }
    .prose :global(p) {
      font-size: 1.05rem; line-height: 1.7;
      color: color-mix(in srgb, var(--ink) 88%, var(--bg-dark));
      margin: 0 0 1.1rem;
    }
    .prose :global(ul), .prose :global(ol) { margin: 0 0 1.2rem; padding-inline-start: 1.4rem; }
    .prose :global(li) { font-size: 1.05rem; line-height: 1.6; margin-bottom: 0.4rem; }
    .prose :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 0.18em;
      text-decoration-thickness: 1px;
    }
    .prose :global(strong) { font-weight: 700; }
    .prose :global(blockquote) {
      margin: 1.6rem 0; padding-inline-start: 1.2rem;
      border-inline-start: 2px solid var(--accent);
      color: color-mix(in srgb, var(--ink) 75%, var(--bg-dark));
      font-style: italic;
    }
    .prose :global(hr) {
      border: 0; height: 1px;
      background: color-mix(in srgb, var(--muted) 40%, transparent);
      margin: 2.4rem 0;
    }
    .prose :global(code) {
      font-family: var(--f-mono); font-size: 0.9em;
      background: color-mix(in srgb, var(--muted) 18%, transparent);
      padding: 0.15em 0.4em; border-radius: 3px;
    }
    .prose :global(img) { border-radius: 6px; margin: 1.6rem 0; }
  </style>
</Base>
