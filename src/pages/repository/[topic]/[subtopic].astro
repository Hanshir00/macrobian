---
export const prerender = true;

import Base from '../../../layouts/Base.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const subtopics = await getCollection('repoSubtopics');
  const topics = await getCollection('repoTopics');
  return subtopics.map((sub) => {
    const parent = topics.find((t) => t.data.slug === sub.data.topic);
    return {
      params: { topic: sub.data.topic, subtopic: sub.data.slug },
      props: { subtopic: sub, topic: parent },
    };
  });
}

const { subtopic, topic } = Astro.props;

const allLinks = await getCollection('repoLinks');
const links = allLinks
  .filter((l) => l.data.subtopic === subtopic.data.slug)
  .sort((a, b) => (b.data.addedAt?.getTime() ?? 0) - (a.data.addedAt?.getTime() ?? 0));
---

<Base
  title={`${subtopic.data.name} — ${topic?.data.name ?? 'Repository'}`}
  description={subtopic.data.description}
>
  <div class="container container--narrow" data-pagefind-body data-pagefind-meta={`title:${subtopic.data.name}`}>
    <nav class="crumb" aria-label="Breadcrumb" data-pagefind-ignore>
      <a href="/repository">Repository</a>
      <span aria-hidden="true">/</span>
      {topic && (
        <>
          <a href={`/repository/${topic.data.slug}`}>{topic.data.name}</a>
          <span aria-hidden="true">/</span>
        </>
      )}
      <span>{subtopic.data.name}</span>
    </nav>

    <header class="page-head">
      <span class="eyebrow page-head__eyebrow">{topic?.data.name ?? 'Subtopic'}</span>
      <h1 class="page-head__title">{subtopic.data.name}</h1>
      {subtopic.data.description && <p class="page-head__desc">{subtopic.data.description}</p>}
    </header>

    {links.length === 0 ? (
      <p class="empty" data-pagefind-ignore>No entries under this subtopic yet.</p>
    ) : (
      <ul class="link-list">
        {links.map((link) => (
          <li>
            <EntryCard
              href={link.data.url}
              title={link.data.title}
              meta={[link.data.type, link.data.author, link.data.year].filter(Boolean).join(' · ')}
              description={link.data.description}
              external={true}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .crumb {
    display: flex; align-items: center; gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
    flex-wrap: wrap;
  }
  .crumb a { color: var(--c-ink-mute); }
  .crumb a:hover { color: var(--c-ink); }
  .crumb span[aria-hidden] { color: var(--c-rule); }

  .page-head { padding-block: var(--s-12) var(--s-10); max-width: 38rem; }
  .page-head__eyebrow { color: var(--c-bark-deep); margin-bottom: var(--s-5); display: block; }
  .page-head__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-3xl), 6vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 144;
    margin: 0;
  }
  .page-head__desc {
    margin-top: var(--s-5);
    font-size: var(--t-md);
    line-height: var(--ld-relaxed);
    color: var(--c-ink-mute);
    max-width: 50ch;
  }

  .link-list { list-style: none; margin: 0; padding: 0; }
  .empty { padding: var(--s-8) 0; color: var(--c-ink-mute); font-size: var(--t-sm); }
</style>
