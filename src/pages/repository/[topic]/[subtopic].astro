---
import Base from '../../../layouts/Base.astro';
import PageHeader from '../../../components/PageHeader.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const subtopics = await getCollection('repo-subtopics');
  const topics = await getCollection('repo-topics');
  return subtopics.map((sub) => {
    const parent = topics.find((t) => t.data.slug === sub.data.topic);
    return {
      params: { topic: sub.data.topic, subtopic: sub.data.slug },
      props: { subtopic: sub, topic: parent },
    };
  });
}

const { subtopic, topic } = Astro.props;

const allLinks = await getCollection('repo-links');
const links = allLinks
  .filter((l) => l.data.subtopic === subtopic.data.slug)
  .sort((a, b) => {
    const da = a.data.addedAt?.getTime() ?? 0;
    const db = b.data.addedAt?.getTime() ?? 0;
    return db - da;
  });
---

<Base
  title={`${subtopic.data.name} — ${topic?.data.name ?? 'Repository'}`}
  description={subtopic.data.description}
>
  <div class="container container--narrow">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/repository">Repository</a>
      <span aria-hidden="true">/</span>
      {topic && (
        <>
          <a href={`/repository/${topic.data.slug}`}>{topic.data.name}</a>
          <span aria-hidden="true">/</span>
        </>
      )}
      <span>{subtopic.data.name}</span>
    </nav>

    <PageHeader
      eyebrow={topic?.data.name ?? 'Subtopic'}
      title={subtopic.data.name}
      description={subtopic.data.description}
    />

    {links.length === 0 ? (
      <p class="empty">No entries under this subtopic yet.</p>
    ) : (
      <ul class="link-list">
        {links.map((link) => (
          <li>
            <EntryCard
              href={link.data.url}
              title={link.data.title}
              meta={[link.data.type, link.data.author, link.data.year].filter(Boolean).join(' · ')}
              description={link.data.description}
              external={true}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .crumb {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
    flex-wrap: wrap;
  }

  .crumb a {
    color: var(--c-ink-mute);
  }

  .crumb a:hover {
    color: var(--c-ink);
  }

  .crumb span[aria-hidden] {
    color: var(--c-rule);
  }

  .link-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .empty {
    padding: var(--s-8) 0;
    color: var(--c-ink-mute);
    font-size: var(--t-sm);
  }
</style>
