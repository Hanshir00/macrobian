---
import Base from '../../../layouts/Base.astro';
import PageHeader from '../../../components/PageHeader.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const topics = await getCollection('repo-topics');
  return topics.map((topic) => ({
    params: { topic: topic.data.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;

const allSubtopics = await getCollection('repo-subtopics');
const allLinks = await getCollection('repo-links');

// Subtopics under this topic
const subtopics = allSubtopics
  .filter((s) => s.data.topic === topic.data.slug)
  .sort((a, b) => {
    const oa = a.data.order ?? 999;
    const ob = b.data.order ?? 999;
    if (oa !== ob) return oa - ob;
    return a.data.name.localeCompare(b.data.name);
  });

// Direct links (no subtopic) under this topic
const directLinks = allLinks
  .filter((l) => l.data.topic === topic.data.slug && !l.data.subtopic)
  .sort((a, b) => {
    const da = a.data.addedAt?.getTime() ?? 0;
    const db = b.data.addedAt?.getTime() ?? 0;
    return db - da;
  });

// Counts per subtopic
const countsBySubtopic = allLinks.reduce<Record<string, number>>((acc, link) => {
  if (link.data.subtopic) {
    acc[link.data.subtopic] = (acc[link.data.subtopic] ?? 0) + 1;
  }
  return acc;
}, {});
---

<Base
  title={topic.data.name}
  description={topic.data.description ?? `${topic.data.name} — a section of the repository.`}
>
  <div class="container container--narrow">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/repository">Repository</a>
      <span aria-hidden="true">/</span>
      <span>{topic.data.name}</span>
    </nav>

    <PageHeader
      eyebrow="Topic"
      title={topic.data.name}
      description={topic.data.description}
    />

    {subtopics.length > 0 && (
      <section class="section">
        <h2 class="section__title eyebrow">Subtopics</h2>
        <ul class="subtopic-list">
          {subtopics.map((sub) => (
            <li>
              <a href={`/repository/${topic.data.slug}/${sub.data.slug}`} class="subtopic-card">
                <span class="subtopic-card__name">{sub.data.name}</span>
                <span class="subtopic-card__count">
                  {countsBySubtopic[sub.data.slug] ?? 0}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {directLinks.length > 0 && (
      <section class="section">
        <h2 class="section__title eyebrow">Entries</h2>
        <ul class="link-list">
          {directLinks.map((link) => (
            <li>
              <EntryCard
                href={link.data.url}
                title={link.data.title}
                meta={[link.data.type, link.data.author, link.data.year].filter(Boolean).join(' · ')}
                description={link.data.description}
                external={true}
              />
            </li>
          ))}
        </ul>
      </section>
    )}

    {subtopics.length === 0 && directLinks.length === 0 && (
      <p class="empty">No entries under this topic yet.</p>
    )}
  </div>
</Base>

<style>
  .crumb {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
  }

  .crumb a {
    color: var(--c-ink-mute);
  }

  .crumb a:hover {
    color: var(--c-ink);
  }

  .crumb span[aria-hidden] {
    color: var(--c-rule);
  }

  .section {
    margin-bottom: var(--s-12);
  }

  .section__title {
    color: var(--c-bark-deep);
    margin-bottom: var(--s-5);
    display: block;
  }

  .subtopic-list,
  .link-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .subtopic-list {
    display: grid;
    gap: var(--s-3);
    grid-template-columns: 1fr;
  }

  @media (min-width: 600px) {
    .subtopic-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .subtopic-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s-5) var(--s-6);
    background: var(--c-paper-deep);
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-md);
    color: var(--c-ink);
    text-decoration: none;
    transition:
      transform var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .subtopic-card:hover {
    transform: translateY(-1px);
    border-color: var(--c-moss-deep);
  }

  .subtopic-card__name {
    font-family: var(--f-display);
    font-size: var(--t-lg);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 96, 'SOFT' 30;
  }

  .subtopic-card__count {
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--t-md);
    color: var(--c-ink-mute);
    font-variation-settings: 'opsz' 24;
  }

  .empty {
    padding: var(--s-8) 0;
    color: var(--c-ink-mute);
    font-size: var(--t-sm);
  }
</style>
