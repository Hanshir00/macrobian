---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const topics = await getCollection('repo-topics');
const links = await getCollection('repo-links');

// Sort by order then name
const sortedTopics = topics.sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});

// Counts per topic for the listing
const countsByTopic = links.reduce<Record<string, number>>((acc, link) => {
  acc[link.data.topic] = (acc[link.data.topic] ?? 0) + 1;
  return acc;
}, {});
---

<Base title="Repository" description="A personal repository of literature, studies, and books.">
  <div class="container container--narrow">
    <PageHeader
      eyebrow="Repository"
      title="A working library."
      description="An ongoing archive of literature, studies, and books. Organized by topic, expanded over time."
    />

    {sortedTopics.length === 0 ? (
      <p class="empty">No topics yet. Add your first topic in the CMS at <code>/admin</code>.</p>
    ) : (
      <ul class="topic-list">
        {sortedTopics.map((topic) => (
          <li class="topic-list__item">
            <a href={`/repository/${topic.data.slug}`} class="topic-card">
              <div class="topic-card__head">
                <h2 class="topic-card__name">{topic.data.name}</h2>
                <span class="topic-card__count eyebrow">
                  {countsByTopic[topic.data.slug] ?? 0} entries
                </span>
              </div>
              {topic.data.description && (
                <p class="topic-card__desc">{topic.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .topic-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .topic-card {
    display: block;
    padding: var(--s-6) 0;
    border-top: 1px solid var(--c-rule);
    color: var(--c-ink);
    text-decoration: none;
    transition: padding-left var(--dur-fast) var(--ease-out);
  }

  .topic-list__item:last-child .topic-card {
    border-bottom: 1px solid var(--c-rule);
  }

  .topic-card:hover {
    padding-left: var(--s-3);
  }

  .topic-card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-4);
    flex-wrap: wrap;
  }

  .topic-card__name {
    font-family: var(--f-display);
    font-size: clamp(var(--t-xl), 3.5vw, var(--t-2xl));
    font-weight: 400;
    color: var(--c-ink-soft);
    letter-spacing: var(--tr-tight);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    margin: 0;
  }

  .topic-card__count {
    color: var(--c-ink-mute);
    font-size: var(--t-xs);
  }

  .topic-card__desc {
    margin-top: var(--s-3);
    font-size: var(--t-sm);
    color: var(--c-ink-mute);
    line-height: var(--ld-relaxed);
    max-width: 60ch;
  }

  .empty {
    padding: var(--s-8) 0;
    color: var(--c-ink-mute);
    font-size: var(--t-sm);
  }

  code {
    font-family: var(--f-mono);
    font-size: 0.85em;
    padding: 0.1em 0.3em;
    background: var(--c-paper-deep);
    border-radius: var(--radius-sm);
  }
</style>
