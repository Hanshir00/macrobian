---
import Base from '../../../layouts/Base.astro';
import PageHeader from '../../../components/PageHeader.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

const peptides = await getCollection('peptides', ({ data }) => !data.draft);

const sorted = peptides.sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return a.data.title.localeCompare(b.data.title);
});
---

<Base
  title="Peptides"
  description="A working catalog of peptides, with summaries and sources."
>
  <div class="container container--narrow">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/sanguine">Sanguine</a>
      <span aria-hidden="true">/</span>
      <span>Peptides</span>
    </nav>

    <PageHeader
      eyebrow="Sanguine"
      title="Peptides"
      description="Compounds organized for clarity — categorized, sourced, and summarized."
    />

    {sorted.length === 0 ? (
      <p class="empty">No peptides yet. Add one in the CMS at <code>/admin</code>.</p>
    ) : (
      <ul class="entry-list">
        {sorted.map((entry) => (
          <li>
            <EntryCard
              href={`/sanguine/peptides/${entry.slug}`}
              title={entry.data.title}
              meta={entry.data.category}
              description={entry.data.summary}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .crumb {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
  }

  .crumb a { color: var(--c-ink-mute); }
  .crumb a:hover { color: var(--c-ink); }
  .crumb span[aria-hidden] { color: var(--c-rule); }

  .entry-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .empty {
    padding: var(--s-8) 0;
    color: var(--c-ink-mute);
    font-size: var(--t-sm);
  }

  code {
    font-family: var(--f-mono);
    font-size: 0.85em;
    padding: 0.1em 0.3em;
    background: var(--c-paper-deep);
    border-radius: var(--radius-sm);
  }
</style>
