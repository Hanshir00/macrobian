---
export const prerender = true;

import Base from '../../../layouts/Base.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

const nootropics = await getCollection('nootropics', ({ data }) => !data.draft);

const sorted = nootropics.sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id);
});
---

<Base
  title="Nootropics"
  description="A working catalog of nootropics, with summaries and sources."
>
  <div class="container container--narrow" data-pagefind-body data-pagefind-meta="title:Nootropics">
    <nav class="crumb" aria-label="Breadcrumb" data-pagefind-ignore>
      <a href="/sanguine">Sanguine</a>
      <span aria-hidden="true">/</span>
      <span>Nootropics</span>
    </nav>

    <header class="page-head">
      <span class="eyebrow page-head__eyebrow">Sanguine</span>
      <h1 class="page-head__title">Nootropics</h1>
      <p class="page-head__desc">Cognitive compounds, ranked and explained — from established to experimental.</p>
    </header>

    {sorted.length === 0 ? (
      <p class="empty" data-pagefind-ignore>No nootropics yet. Add one in <a href="/keystatic">the editor</a>.</p>
    ) : (
      <ul class="entry-list">
        {sorted.map((entry) => (
          <li>
            <EntryCard
              href={`/sanguine/nootropics/${entry.id}`}
              title={entry.data.title ?? entry.id}
              meta={entry.data.category}
              description={entry.data.summary}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .crumb {
    display: flex; align-items: center; gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
  }
  .crumb a { color: var(--c-ink-mute); }
  .crumb a:hover { color: var(--c-ink); }
  .crumb span[aria-hidden] { color: var(--c-rule); }

  .page-head { padding-block: var(--s-12) var(--s-10); max-width: 38rem; }
  .page-head__eyebrow { color: var(--c-bark-deep); margin-bottom: var(--s-5); display: block; }
  .page-head__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-3xl), 6vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 144;
    margin: 0;
  }
  .page-head__desc {
    margin-top: var(--s-5);
    font-size: var(--t-md);
    line-height: var(--ld-relaxed);
    color: var(--c-ink-mute);
    max-width: 50ch;
  }

  .entry-list { list-style: none; margin: 0; padding: 0; }
  .empty { padding: var(--s-8) 0; color: var(--c-ink-mute); font-size: var(--t-sm); }
</style>
