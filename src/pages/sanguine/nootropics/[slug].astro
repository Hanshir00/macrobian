---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const nootropics = await getCollection('nootropics', ({ data }) => !data.draft);
  return nootropics.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Base
  title={entry.data.title}
  description={entry.data.summary}
>
  <article class="container container--prose article">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/sanguine">Sanguine</a>
      <span aria-hidden="true">/</span>
      <a href="/sanguine/nootropics">Nootropics</a>
      <span aria-hidden="true">/</span>
      <span>{entry.data.title}</span>
    </nav>

    <header class="article__header">
      {entry.data.category && (
        <span class="eyebrow article__category">{entry.data.category}</span>
      )}
      <h1 class="article__title">{entry.data.title}</h1>
      {entry.data.aliases && entry.data.aliases.length > 0 && (
        <p class="article__aliases">
          Also known as: {entry.data.aliases.join(', ')}
        </p>
      )}
      <p class="article__summary">{entry.data.summary}</p>
    </header>

    <div class="prose article__body">
      <Content />
    </div>

    {entry.data.updatedAt && (
      <footer class="article__footer">
        <p class="eyebrow">
          Updated {entry.data.updatedAt.toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          })}
        </p>
      </footer>
    )}
  </article>
</Base>

<style>
  .crumb {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
    flex-wrap: wrap;
  }

  .crumb a { color: var(--c-ink-mute); }
  .crumb a:hover { color: var(--c-ink); }
  .crumb span[aria-hidden] { color: var(--c-rule); }

  .article {
    padding-bottom: var(--s-12);
  }

  .article__header {
    padding-block: var(--s-12) var(--s-8);
    border-bottom: 1px solid var(--c-rule);
    margin-bottom: var(--s-10);
  }

  .article__category {
    color: var(--c-bark-deep);
    margin-bottom: var(--s-4);
    display: block;
  }

  .article__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-3xl), 6vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    margin: 0;
  }

  .article__aliases {
    margin-top: var(--s-4);
    font-size: var(--t-sm);
    color: var(--c-ink-mute);
    font-style: italic;
  }

  .article__summary {
    margin-top: var(--s-5);
    font-family: var(--f-display);
    font-style: italic;
    font-size: var(--t-md);
    line-height: var(--ld-relaxed);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 96, 'SOFT' 100;
  }

  .article__body :global(h2) {
    margin-top: var(--s-10);
    margin-bottom: var(--s-4);
    font-size: var(--t-xl);
    color: var(--c-ink-soft);
  }

  .article__body :global(h3) {
    margin-top: var(--s-8);
    margin-bottom: var(--s-3);
    font-size: var(--t-lg);
    color: var(--c-ink-soft);
  }

  .article__body :global(p) {
    margin-bottom: var(--s-5);
  }

  .article__footer {
    margin-top: var(--s-12);
    padding-top: var(--s-6);
    border-top: 1px solid var(--c-rule);
    color: var(--c-ink-mute);
  }
</style>
