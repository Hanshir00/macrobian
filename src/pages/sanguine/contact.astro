---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site } from '../../config/site';

const activeSocials = Object.entries(site.socials).filter(([, url]) => url);
---

<Base
  title="Contact"
  description="Get in touch."
>
  <div class="container container--narrow">
    <nav class="crumb" aria-label="Breadcrumb">
      <a href="/sanguine">Sanguine</a>
      <span aria-hidden="true">/</span>
      <span>Contact</span>
    </nav>

    <PageHeader
      eyebrow="Sanguine"
      title="Contact"
      description="The fastest way to reach me."
    />

    <section class="contact">
      <div class="contact__row">
        <span class="eyebrow contact__label">Email</span>
        <a href={`mailto:${site.author.email}`} class="contact__value">
          {site.author.email}
        </a>
      </div>

      {activeSocials.length > 0 && (
        <div class="contact__row">
          <span class="eyebrow contact__label">Elsewhere</span>
          <ul class="contact__socials">
            {activeSocials.map(([key, url]) => (
              <li>
                <a href={url as string} target="_blank" rel="noopener noreferrer">
                  {key}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  </div>
</Base>

<style>
  .crumb {
    display: flex;
    align-items: center;
    gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
  }

  .crumb a { color: var(--c-ink-mute); }
  .crumb a:hover { color: var(--c-ink); }
  .crumb span[aria-hidden] { color: var(--c-rule); }

  .contact {
    display: grid;
    gap: var(--s-8);
    margin-top: var(--s-6);
  }

  .contact__row {
    display: grid;
    gap: var(--s-3);
    padding-block: var(--s-6);
    border-top: 1px solid var(--c-rule);
  }

  .contact__row:last-child {
    border-bottom: 1px solid var(--c-rule);
  }

  .contact__label {
    color: var(--c-bark-deep);
  }

  .contact__value {
    font-family: var(--f-display);
    font-size: clamp(var(--t-xl), 4vw, var(--t-3xl));
    color: var(--c-ink-soft);
    letter-spacing: var(--tr-tight);
    font-variation-settings: 'opsz' 144, 'SOFT' 50;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
    word-break: break-word;
  }

  .contact__value:hover {
    color: var(--c-bark-deep);
  }

  .contact__socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }

  .contact__socials a {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    color: var(--c-ink-soft);
    text-decoration: none;
    text-transform: capitalize;
    letter-spacing: var(--tr-tight);
    font-variation-settings: 'opsz' 96, 'SOFT' 30;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .contact__socials a:hover {
    color: var(--c-bark-deep);
  }
</style>
