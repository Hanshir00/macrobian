---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import EntryCard from '../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('presentations', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0),
);
---

<Base
  title="Presentations"
  description="Slide decks and visual presentations."
>
  <div class="container container--narrow" data-pagefind-body data-pagefind-meta="title:Presentations">
    <header class="page-head">
      <span class="eyebrow page-head__eyebrow">Presentations</span>
      <h1 class="page-head__title">Decks &amp; visuals.</h1>
      <p class="page-head__desc">Standalone slide decks and visual presentations, viewable in the browser.</p>
    </header>

    {sorted.length === 0 ? (
      <p class="empty" data-pagefind-ignore>No presentations yet. Add one in <a href="/keystatic">the editor</a>.</p>
    ) : (
      <ul class="entry-list">
        {sorted.map((entry) => (
          <li>
            <EntryCard
              href={`/presentations/${entry.id}`}
              title={entry.data.title}
              meta={entry.data.date
                ? entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
                : undefined}
              description={entry.data.summary}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</Base>

<style>
  .page-head { padding-block: var(--s-12) var(--s-10); max-width: 38rem; }
  .page-head__eyebrow { color: var(--c-bark-deep); margin-bottom: var(--s-5); display: block; }
  .page-head__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-3xl), 6vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 144;
    margin: 0;
  }
  .page-head__desc {
    margin-top: var(--s-5);
    font-size: var(--t-md);
    line-height: var(--ld-relaxed);
    color: var(--c-ink-mute);
    max-width: 50ch;
  }
  .entry-list { list-style: none; margin: 0; padding: 0; }
  .empty { padding: var(--s-8) 0; color: var(--c-ink-mute); font-size: var(--t-sm); }
</style>
