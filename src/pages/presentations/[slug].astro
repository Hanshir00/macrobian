---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('presentations', ({ data }) => !data.draft);
  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
// Prefer an uploaded deck file; fall back to a manually entered path/URL.
const deckSrc = entry.data.deckFile || entry.data.deckUrl || '';
const hasDeck = deckSrc.trim().length > 0;
---

<Base title={entry.data.title} description={entry.data.summary}>
  <div class="container container--narrow">
    <nav class="crumb" aria-label="Breadcrumb" data-pagefind-ignore>
      <a href="/presentations">Presentations</a>
      <span aria-hidden="true">/</span>
      <span>{entry.data.title}</span>
    </nav>

    <header class="deck-head">
      <h1 class="deck-head__title">{entry.data.title}</h1>
      {entry.data.summary && <p class="deck-head__summary">{entry.data.summary}</p>}
      {hasDeck && (
        <a class="deck-head__open" href={deckSrc} target="_blank" rel="noopener noreferrer">
          Open fullscreen ↗
        </a>
      )}
    </header>
  </div>

  {hasDeck ? (
    <div class="deck-frame-wrap">
      <iframe
        class="deck-frame"
        src={deckSrc}
        title={entry.data.title}
        loading="lazy"
        allowfullscreen
      ></iframe>
    </div>
  ) : (
    <div class="container container--narrow">
      <p class="empty" data-pagefind-ignore>
        This presentation has no deck attached yet. Add one in <a href="/keystatic">the editor</a>.
      </p>
    </div>
  )}
</Base>

<style>
  .crumb {
    display: flex; align-items: center; gap: var(--s-2);
    padding-top: var(--s-8);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-ink-mute);
  }
  .crumb a { color: var(--c-ink-mute); }
  .crumb a:hover { color: var(--c-ink); }
  .crumb span[aria-hidden] { color: var(--c-rule); }

  .deck-head { padding-block: var(--s-10) var(--s-6); }
  .deck-head__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-2xl), 5vw, var(--t-4xl));
    line-height: var(--ld-tight);
    letter-spacing: var(--tr-tight);
    color: var(--c-ink-soft);
    font-variation-settings: 'opsz' 144;
    margin: 0;
  }
  .deck-head__summary {
    margin-top: var(--s-4);
    font-size: var(--t-md);
    color: var(--c-ink-mute);
    line-height: var(--ld-relaxed);
    max-width: 60ch;
  }
  .deck-head__open {
    display: inline-block;
    margin-top: var(--s-5);
    font-size: var(--t-xs);
    letter-spacing: var(--tr-eyebrow);
    text-transform: uppercase;
    color: var(--c-bark-deep);
  }
  .deck-head__open:hover { color: var(--c-ink); }

  .deck-frame-wrap {
    width: 100%;
    max-width: var(--container-max);
    margin: var(--s-6) auto var(--s-12);
    padding-inline: var(--s-4);
  }
  .deck-frame {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--c-rule);
    border-radius: var(--radius-md);
    background: var(--c-paper-deep);
    box-shadow: var(--shadow-md);
  }
  .empty { padding: var(--s-8) 0; color: var(--c-ink-mute); font-size: var(--t-sm); }
</style>
