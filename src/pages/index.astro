---
export const prerender = true;

import { getLanding, getThemeStyle, getGoogleFontsUrl } from '../config/landing';
import Search from '../components/Search.astro';
import '../styles/global.css';

const d = getLanding();
const themeCss = getThemeStyle(d);
const fontsUrl = getGoogleFontsUrl(d);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{d.brandName} — {d.eyebrowLeft}</title>
    <meta name="description" content={d.description} />
    <meta name="theme-color" content={d.theme.colorBgLight} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={new URL('/', Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${d.brandName} — ${d.eyebrowLeft}`} />
    <meta property="og:description" content={d.description} />
    <meta property="og:url" content={new URL('/', Astro.site)} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${d.brandName} — ${d.eyebrowLeft}`} />
    <meta name="twitter:description" content={d.description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <style is:inline set:html={themeCss}></style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />
  </head>

  <body data-pagefind-ignore>
    <main class="stage">
      <!-- Top bar -->
      <header class="topbar">
<a class="brand" href="/">
          <span class="brand__sun" aria-hidden="true">
            <svg viewBox="0 0 200 200" fill="none">
              <g class="sun__long" stroke="currentColor" stroke-width="9" stroke-linecap="round">
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(0 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(30 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(60 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(90 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(120 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(150 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(180 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(210 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(240 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(270 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(300 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="12" transform="rotate(330 100 100)"/>
              </g>
              <g class="sun__short" stroke="currentColor" stroke-width="9" stroke-linecap="round">
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(15 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(45 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(75 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(105 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(135 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(165 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(195 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(225 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(255 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(285 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(315 100 100)"/>
                <line x1="100" y1="60" x2="100" y2="36" transform="rotate(345 100 100)"/>
              </g>
            </svg>
          </span>
          <span class="brand__name">{d.brandName}</span>
          <span class="brand__ver">{d.brandVersion}</span>
        </a>
        <div class="topbar__right">
          <nav class="nav" aria-label="Primary">
            {d.nav.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
          <details class="menu">
            <summary>Menu</summary>
            <nav class="menu__panel" aria-label="Primary">
              {d.nav.map((item) => <a href={item.href}>{item.label}</a>)}
            </nav>
          </details>
          <Search />
        </div>
      </header>

      <!-- Left technical rail -->
      <aside class="rail" aria-hidden="true">
        <span class="rail__target">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1"/><circle cx="12" cy="12" r="1.4" fill="currentColor"/></svg>
        </span>
        <span class="rail__label">{d.railAperture}</span>
        <span class="rail__line"></span>
        <span class="rail__readout">{d.railDiameter}</span>
        <span class="rail__readout">{d.railTolerance}</span>
        <span class="rail__readout">{d.railRev}</span>
      </aside>

      <!-- Red measurement spine -->
      <div class="spine" aria-hidden="true">
        <span class="spine__cross">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1"/><line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="1"/><line x1="1" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="1"/></svg>
        </span>
        <div class="spine__textwrap">
          <div class="spine__ticker">
<span class="spine__text">{d.spineText}</span>
            <span class="spine__text" aria-hidden="true">{d.spineText}</span>
            <span class="spine__text" aria-hidden="true">{d.spineText}</span>
            <span class="spine__text" aria-hidden="true">{d.spineText}</span>
          </div>
        </div>
<span class="spine__dial">
          <svg viewBox="0 0 200 200" fill="none">
            <g class="sun__long" stroke="currentColor" stroke-width="5" stroke-linecap="round">
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(0 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(30 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(60 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(90 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(120 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(150 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(180 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(210 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(240 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(270 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(300 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(330 100 100)"/>
            </g>
            <g class="sun__short" stroke="currentColor" stroke-width="5" stroke-linecap="round">
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(15 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(45 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(75 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(105 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(135 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(165 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(195 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(225 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(255 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(285 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(315 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(345 100 100)"/>
            </g>
            <path d="M82,116 L84,84 L100,106 L116,84 L118,116" fill="none" stroke="currentColor" stroke-width="5" opacity="0.55" stroke-linejoin="miter" stroke-linecap="butt" transform="translate(100 100) scale(0.88) translate(-100 -100)"/>
          </svg>
        </span>
        <span class="spine__num">{d.spineNumber}</span>
      </div>

      <!-- Hero -->
      <section class="hero">
        <p class="eyebrow">
          <span class="eyebrow__sq" aria-hidden="true"></span>
          <span>{d.eyebrowLeft}</span>
          <span class="eyebrow__rule" aria-hidden="true"></span>
          <span>{d.eyebrowRight}</span>
        </p>
        <div class="wordmark">
          <h1 class="title">{d.title}</h1>
          <span class="slice-band" aria-hidden="true"></span>
          <span class="title title--white" aria-hidden="true">{d.title}</span>
        </div>
        <p class="desc">{d.description}</p>
        <div class="actions">
          <a class="btn" href={d.primaryHref}>
            <span>{d.primaryLabel}</span>
            <span class="btn__rule" aria-hidden="true"></span>
            <span aria-hidden="true">→</span>
          </a>
<a class="link" href={d.secondaryHref}>
            <span class="link__rule" aria-hidden="true"></span>
            {d.secondaryLabel}
          </a>
        </div>

      </section>
</a>
        </div>
        <div class="hero__mark hero__mark--mobile" aria-hidden="true">
          <svg viewBox="0 0 200 200" fill="none">
            <g class="sun__long" stroke="currentColor" stroke-width="5" stroke-linecap="round">
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(0 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(30 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(60 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(90 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(120 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(150 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(180 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(210 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(240 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(270 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(300 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="12" transform="rotate(330 100 100)"/>
            </g>
            <g class="sun__short" stroke="currentColor" stroke-width="5" stroke-linecap="round">
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(15 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(45 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(75 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(105 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(135 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(165 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(195 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(225 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(255 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(285 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(315 100 100)"/>
              <line x1="100" y1="60" x2="100" y2="36" transform="rotate(345 100 100)"/>
            </g>
            <path d="M82,116 L84,84 L100,106 L116,84 L118,116" fill="none" stroke="currentColor" stroke-width="5" opacity="0.6" stroke-linejoin="miter" stroke-linecap="butt" transform="translate(100 100) scale(0.88) translate(-100 -100)"/>
          </svg>
        </div>
      </section>
      <!-- Footer plate -->
      <footer class="plate">
        <span>{d.footerLeft}</span>
        <span>{d.footerCenter}</span>
        <span>{d.footerRight}</span>
      </footer>
    </main>

    <style define:vars={{ }}>
      .stage {
        position: relative;
        min-height: 100vh;
        min-height: 100svh;
        overflow: hidden;
        background: var(--silver);
      }
      /* film grain — on the backdrop, behind all content */
      .stage::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background-image: var(--grain);
        background-size: 160px 160px;
        opacity: 0.05;
        mix-blend-mode: multiply;
      }

      /* mono helper */
      .nav a, .rail span, .spine__text, .eyebrow, .plate span, .btn, .link, .brand__name, .brand__ver {
        font-family: var(--f-mono);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: calc(0.8rem * var(--type-scale, 1));
      }

      /* Top bar */
      .topbar {
        position: absolute; top: 0; left: 0; right: 0;
        display: flex; align-items: center; justify-content: space-between;
        padding: clamp(1.4rem, 3vw, 2.4rem) clamp(1.4rem, 4vw, 3.2rem);
        z-index: 5;
      }
.brand { display: inline-flex; align-items: center; gap: 0.6rem; }
.brand__sun { width: 20px; height: 20px; color: var(--accent); display: inline-flex; flex: none; }
      .brand__sun svg { width: 100%; height: 100%; }

      /* Counter-rotating sun: long rays one way, short rays the other */
      .sun__long  { transform-origin: 100px 100px; animation: sunSpinCW 24s linear infinite; }
      .sun__short { transform-origin: 100px 100px; animation: sunSpinCCW 32s linear infinite; }
      @keyframes sunSpinCW  { to { transform: rotate(360deg); } }
      @keyframes sunSpinCCW { to { transform: rotate(-360deg); } }
      @media (prefers-reduced-motion: reduce) {
        .sun__long, .sun__short { animation: none; }
      }


      .brand__name { color: var(--ink); font-weight: 500; letter-spacing: 0.22em; font-size: calc(0.6rem * var(--type-scale, 1)); }
      .brand__ver { color: var(--muted); font-size: calc(0.6rem * var(--type-scale, 1)); }
      .topbar__right { display: flex; align-items: center; gap: clamp(1.2rem, 3vw, 2.6rem); }
      .nav { display: flex; gap: clamp(0.6rem, 2vw, 1.6rem); }
      .nav a {
        position: relative; z-index: 0;
        color: var(--muted);
        padding: 0.4em 0.6em;
        transition: color 200ms ease;
      }
      .nav a::before {
        content: ''; position: absolute; inset: 0; z-index: -1;
        background: var(--accent);
        clip-path: inset(0 50% 0 50%);
        transition: clip-path calc(0.5s * (0.4 + var(--m, 0.44))) var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
      }
      .nav a:hover, .nav a:focus-visible { color: var(--bg-light); }
      .nav a:hover::before, .nav a:focus-visible::before { clip-path: inset(0 0 0 0); }

      /* Mobile disclosure menu (hidden on desktop) */
      .menu { display: none; position: relative; }
      .menu > summary {
        list-style: none; cursor: pointer;
        font-family: var(--f-mono); text-transform: uppercase; letter-spacing: 0.16em;
        font-size: 0.7rem; color: var(--muted); padding: 0.45rem 0.2rem;
      }
      .menu > summary::-webkit-details-marker { display: none; }
      .menu[open] > summary { color: var(--ink); }
      .menu__panel {
        position: absolute; right: 0; top: 100%; margin-top: 0.55rem;
        display: flex; flex-direction: column; gap: 0.9rem;
        min-width: 160px; padding: 0.95rem 1.1rem; z-index: 30;
        background: var(--bg-light);
        border: 1px solid color-mix(in srgb, var(--muted) 35%, transparent);
        border-radius: 6px;
      }
      .menu__panel a {
        color: var(--muted); font-family: var(--f-mono); text-transform: uppercase;
        letter-spacing: 0.16em; font-size: 0.72rem; transition: color 160ms ease;
      }
      .menu__panel a:hover { color: var(--ink); }

      /* Left rail */
      .rail {
        position: absolute; top: clamp(7rem, 14vh, 10rem); left: clamp(1.4rem, 4vw, 3.2rem);
        display: flex; flex-direction: column; gap: 0.9rem; color: var(--muted); z-index: 4;
      }
      .rail__target { color: var(--ink); width: 30px; height: 30px; }
      .rail__target svg { width: 100%; height: 100%; }
      .rail__label { color: var(--ink); }
      .rail__line { width: 1px; height: clamp(3rem, 8vh, 5rem); background: var(--ink); opacity: 0.5; margin: 0.4rem 0 0.8rem; }
      .rail__readout { color: var(--muted); }

      /* Red spine */
      .spine {
        position: absolute; top: 0; bottom: 0;
        left: clamp(150px, 24vw, 360px);
        width: clamp(34px, 4vw, 52px);
        background: var(--accent);
        z-index: 3;
        display: flex; flex-direction: column; align-items: center;
      }
      /* tick marks down the right edge */
      .spine::after {
        content: ''; position: absolute; top: 0; bottom: 0; right: 0; width: 8px;
        background: repeating-linear-gradient(to bottom, rgba(255,255,255,0.55) 0 1px, transparent 1px 42px);
      }
      .spine__cross { color: #fff; width: 22px; height: 22px; margin-top: clamp(1.4rem, 3vw, 2.4rem); }
      .spine__cross svg { width: 100%; height: 100%; }
.spine__textwrap {
        position: absolute;
        left: 0; right: 0;
        bottom: 28%;
        top: 4rem;
        overflow: hidden;
        display: flex; justify-content: center;
      }
      .spine__ticker {
        display: flex; flex-direction: column;
animation: spineTick 10.67s linear infinite;
      }
      .spine__text {
        color: #fff; writing-mode: vertical-rl; transform: rotate(180deg);
        letter-spacing: 0.28em; font-size: calc(0.66rem * var(--type-scale, 1));
        white-space: nowrap; padding-block: 1.2rem;
      }
@keyframes spineTick {
        from { transform: translateY(0); }
        to   { transform: translateY(-25%); }
      }
      @media (prefers-reduced-motion: reduce) {
        .spine__ticker { animation: none; }
      }
.spine__dial {
        position: absolute; top: 74%; left: 50%; transform: translate(-50%, -50%);
        width: clamp(60px, 6.5vw, 84px); height: clamp(60px, 6.5vw, 84px);
        color: #fff;
      }
      /* warm glow behind the spine sun's M */
      .spine__dial::before {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        width: 46%; height: 46%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        background: radial-gradient(circle,
          rgba(255, 196, 64, 0.9) 0%,
          rgba(241, 138, 44, 0.6) 38%,
          rgba(218, 58, 44, 0.3) 66%,
          rgba(218, 58, 44, 0) 78%);
        filter: blur(5px);
        z-index: 0;
        pointer-events: none;
      }
      .spine__dial svg { position: relative; z-index: 1; width: 100%; height: 100%; }
      .spine__num { color: #fff; margin-top: auto; margin-bottom: clamp(1.4rem, 3vw, 2.4rem); font-size: calc(0.72rem * var(--type-scale, 1)); }

      /* Hero */
      .hero {
        position: absolute; top: 50%; transform: translateY(-50%);
        left: clamp(210px, 32vw, 460px);
        right: clamp(1.4rem, 6vw, 5rem);
        max-width: 760px;
      }
      .eyebrow { display: flex; align-items: center; gap: 0.9rem; color: var(--muted); margin-bottom: clamp(1rem, 2.5vw, 1.8rem); flex-wrap: wrap; }
      .eyebrow__sq { width: 11px; height: 11px; background: var(--accent); display: inline-block; }
      .eyebrow span:not(.eyebrow__sq):not(.eyebrow__rule) { color: var(--ink); }
      .eyebrow__rule { width: clamp(1.4rem, 4vw, 3rem); height: 1px; background: var(--muted); display: inline-block; }

      /* ---------- Slice hero treatment ---------- */
      .wordmark { position: relative; display: inline-block; z-index: 0; }
      .title {
        position: relative;
        z-index: 1;
        font-family: var(--f-display);
        font-weight: 700;
        font-size: calc(clamp(3.6rem, 11vw, 9.5rem) * var(--type-scale, 1));
        line-height: 0.9;
        letter-spacing: -0.035em;
        color: var(--ink);
      }
      /* full-bleed red band crossing the lower third of the word */
      .slice-band {
        position: absolute;
        left: 0; right: 0;             /* contained to the word only */
        top: 60%;
        height: 12%;
        background: var(--accent);
        z-index: 2;
        pointer-events: none;
      }
      /* the same word in white, shown only where the band crosses it */
      .title--white {
        position: absolute;
        inset: 0;
        z-index: 3;
        color: #f6f5f3;
clip-path: inset(60% 0 28% 0);   /* matches band: 60% → 72% */
        pointer-events: none;
      }
      .desc {
        margin-top: clamp(1.4rem, 3vw, 2.2rem);
        font-family: var(--f-display);
        font-weight: 400;
        font-size: calc(clamp(1.05rem, 1.7vw, 1.6rem) * var(--type-scale, 1));
        line-height: 1.4;
        color: color-mix(in srgb, var(--ink) 80%, var(--bg-dark));
        max-width: 34ch;
      }

      .actions { margin-top: clamp(2rem, 4vw, 3rem); display: flex; align-items: center; gap: clamp(1.2rem, 3vw, 2.4rem); flex-wrap: wrap; }
      .btn {
        position: relative; z-index: 0; overflow: hidden;
        display: inline-flex; align-items: center; gap: 1rem;
        background: var(--ink); color: var(--bg-light);
        padding: 1.1rem 1.6rem; border-radius: 7px;
      }
      .btn > span { position: relative; z-index: 2; }
      .btn::before {
        content: ''; position: absolute; inset: 0; z-index: 1;
        background: var(--accent);
        clip-path: inset(0 50% 0 50%);
        transition: clip-path calc(0.5s * (0.4 + var(--m, 0.44))) var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
      }
      .btn:hover::before, .btn:focus-visible::before { clip-path: inset(0 0 0 0); }
      .btn__rule { width: 1.6rem; height: 1px; background: currentColor; opacity: 0.6; }
      .link { display: inline-flex; align-items: center; gap: 0.8rem; color: var(--muted); transition: color 160ms ease; }
      .link:hover { color: var(--ink); }
      .link__rule { width: 1.6rem; height: 1px; background: var(--muted); }

      /* Footer plate */
      .plate {
        position: absolute; bottom: 0; left: 0; right: 0;
        display: flex; justify-content: space-between;
        padding: clamp(1.2rem, 3vw, 2.2rem) clamp(1.4rem, 4vw, 3.2rem);
        color: var(--muted); z-index: 4;
      }
      .plate span { font-size: calc(0.68rem * var(--type-scale, 1)); }
      .plate span:nth-child(2) { position: absolute; left: 50%; transform: translateX(-50%); }

      /* ---------- Responsive ---------- */
/* Mobile-only hero sun — hidden on desktop (desktop uses the spine sun) */
      .hero__mark--mobile {
        display: none;
        position: relative;
        width: clamp(96px, 32vw, 150px);
        height: clamp(96px, 32vw, 150px);
        margin-top: clamp(2.4rem, 8vw, 3.6rem);
        color: var(--ink);
        opacity: 0.9;
      }
      .hero__mark--mobile::before {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        width: 46%; height: 46%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        background: radial-gradient(circle,
          rgba(255, 196, 64, 0.9) 0%,
          rgba(241, 138, 44, 0.6) 38%,
          rgba(218, 58, 44, 0.3) 66%,
          rgba(218, 58, 44, 0) 78%);
        filter: blur(6px);
        z-index: 0;
        pointer-events: none;
      }
      .hero__mark--mobile svg { position: relative; z-index: 1; width: 100%; height: 100%; }

      @media (max-width: 900px) {
        .stage { min-height: 100svh; }
        .hero__mark--mobile { display: block; }
        .rail { display: none; }
        .spine { width: 8px; left: 0; }
        .spine::after, .spine__cross, .spine__textwrap, .spine__dial, .spine__num { display: none; }
        .nav { display: none; }
        .menu { display: block; }
        .hero {
          position: static; transform: none;
          padding: 8rem 1.6rem 7rem 2rem; left: auto; right: auto; max-width: none;
        }
        .title { font-size: calc(clamp(2.6rem, 14vw, 6rem) * var(--type-scale, 1)); overflow-wrap: break-word; }
        .desc { max-width: none; }
        .plate { flex-direction: column; gap: 0.4rem; align-items: flex-start; }
        .plate span:nth-child(2) { position: static; transform: none; }
      }
    </style>
  </body>
</html>
