---
export const prerender = true;

import { getLanding, getThemeStyle, getGoogleFontsUrl } from '../config/landing';
import Search from '../components/Search.astro';
import '../styles/global.css';

const d = getLanding();
const themeCss = getThemeStyle(d);
const fontsUrl = getGoogleFontsUrl(d);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{d.brandName} — {d.eyebrowLeft}</title>
    <meta name="description" content={d.description} />
    <meta name="theme-color" content={d.theme.colorBgLight} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:inline set:html={themeCss}></style>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />
  </head>

  <body data-pagefind-ignore>
    <main class="stage">
      <!-- Top bar -->
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand__dot" aria-hidden="true"></span>
          <span class="brand__name">{d.brandName}</span>
          <span class="brand__ver">{d.brandVersion}</span>
        </a>
        <nav class="nav" aria-label="Primary">
          {d.nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
        <Search />
      </header>

      <!-- Left technical rail -->
      <aside class="rail" aria-hidden="true">
        <span class="rail__target">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1"/><circle cx="12" cy="12" r="1.4" fill="currentColor"/></svg>
        </span>
        <span class="rail__label">{d.railAperture}</span>
        <span class="rail__line"></span>
        <span class="rail__readout">{d.railDiameter}</span>
        <span class="rail__readout">{d.railTolerance}</span>
        <span class="rail__readout">{d.railRev}</span>
      </aside>

      <!-- Red measurement spine -->
      <div class="spine" aria-hidden="true">
        <span class="spine__cross">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1"/><line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="1"/><line x1="1" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="1"/></svg>
        </span>
        <span class="spine__text">{d.spineText}</span>
        <span class="spine__dial">
          <svg viewBox="0 0 64 64">
            <defs>
              <radialGradient id="metal" cx="38%" cy="32%" r="75%">
                <stop offset="0%" stop-color="#fdfdfd"/>
                <stop offset="45%" stop-color="#d8d8d6"/>
                <stop offset="75%" stop-color="#a9a9a6"/>
                <stop offset="100%" stop-color="#bdbdba"/>
              </radialGradient>
            </defs>
            <circle cx="32" cy="32" r="30" fill="url(#metal)" stroke="#7d7d79" stroke-width="1"/>
            <circle cx="32" cy="32" r="22" fill="none" stroke="#ffffff" stroke-width="1" opacity="0.6"/>
            <circle cx="32" cy="32" r="14" fill="none" stroke="#8d8d89" stroke-width="1"/>
            <circle cx="32" cy="32" r="3.2" fill="#3a3a38"/>
          </svg>
        </span>
        <span class="spine__num">{d.spineNumber}</span>
      </div>

      <!-- Hero -->
      <section class="hero">
        <p class="eyebrow">
          <span class="eyebrow__sq" aria-hidden="true"></span>
          <span>{d.eyebrowLeft}</span>
          <span class="eyebrow__rule" aria-hidden="true"></span>
          <span>{d.eyebrowRight}</span>
        </p>
        <h1 class="title">{d.title}</h1>
        <p class="desc">{d.description}</p>
        <div class="actions">
          <a class="btn" href={d.primaryHref}>
            <span>{d.primaryLabel}</span>
            <span class="btn__rule" aria-hidden="true"></span>
            <span aria-hidden="true">→</span>
          </a>
          <a class="link" href={d.secondaryHref}>
            <span class="link__rule" aria-hidden="true"></span>
            {d.secondaryLabel}
          </a>
        </div>
      </section>

      <!-- Footer plate -->
      <footer class="plate">
        <span>{d.footerLeft}</span>
        <span>{d.footerCenter}</span>
        <span>{d.footerRight}</span>
      </footer>
    </main>

    <style define:vars={{ }}>
      .stage {
        position: relative;
        min-height: 100vh;
        min-height: 100svh;
        overflow: hidden;
        background:
          radial-gradient(120% 90% at 12% 8%, var(--bg-light), transparent 60%),
          linear-gradient(135deg, var(--bg-light) 0%, var(--bg-dark) 100%);
      }

      /* mono helper */
      .nav a, .rail span, .spine__text, .eyebrow, .plate span, .btn, .link, .brand__name, .brand__ver {
        font-family: var(--f-mono);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: 0.72rem;
      }

      /* Top bar */
      .topbar {
        position: absolute; top: 0; left: 0; right: 0;
        display: flex; align-items: center; justify-content: space-between;
        padding: clamp(1.4rem, 3vw, 2.4rem) clamp(1.4rem, 4vw, 3.2rem);
        z-index: 5;
      }
      .brand { display: inline-flex; align-items: center; gap: 0.75rem; }
      .brand__dot { width: 12px; height: 12px; border-radius: 50%; background: var(--muted); }
      .brand__name { color: var(--ink); font-weight: 500; letter-spacing: 0.22em; }
      .brand__ver { color: var(--muted); }
      .nav { display: flex; gap: clamp(1.2rem, 3vw, 2.6rem); }
      .nav a { color: var(--muted); transition: color 160ms ease; }
      .nav a:hover { color: var(--ink); }

      /* Left rail */
      .rail {
        position: absolute; top: clamp(7rem, 14vh, 10rem); left: clamp(1.4rem, 4vw, 3.2rem);
        display: flex; flex-direction: column; gap: 0.9rem; color: var(--muted); z-index: 4;
      }
      .rail__target { color: var(--ink); width: 30px; height: 30px; }
      .rail__target svg { width: 100%; height: 100%; }
      .rail__label { color: var(--ink); }
      .rail__line { width: 1px; height: clamp(3rem, 8vh, 5rem); background: var(--ink); opacity: 0.5; margin: 0.4rem 0 0.8rem; }
      .rail__readout { color: var(--muted); }

      /* Red spine */
      .spine {
        position: absolute; top: 0; bottom: 0;
        left: clamp(150px, 24vw, 360px);
        width: clamp(34px, 4vw, 52px);
        background: var(--accent);
        z-index: 3;
        display: flex; flex-direction: column; align-items: center;
      }
      /* tick marks down the right edge */
      .spine::after {
        content: ''; position: absolute; top: 0; bottom: 0; right: 0; width: 8px;
        background: repeating-linear-gradient(to bottom, rgba(255,255,255,0.55) 0 1px, transparent 1px 42px);
      }
      .spine__cross { color: #fff; width: 22px; height: 22px; margin-top: clamp(1.4rem, 3vw, 2.4rem); }
      .spine__cross svg { width: 100%; height: 100%; }
      .spine__text {
        color: #fff; writing-mode: vertical-rl; transform: rotate(180deg);
        margin-top: 2.2rem; letter-spacing: 0.28em; font-size: 0.66rem;
        white-space: nowrap;
      }
      .spine__dial {
        position: absolute; top: 58%; left: 50%; transform: translate(-50%, -50%);
        width: clamp(54px, 6vw, 76px); height: clamp(54px, 6vw, 76px);
        filter: drop-shadow(0 6px 14px rgba(0,0,0,0.25));
      }
      .spine__dial svg { width: 100%; height: 100%; }
      .spine__num { color: #fff; margin-top: auto; margin-bottom: clamp(1.4rem, 3vw, 2.4rem); font-size: 0.72rem; }

      /* Hero */
      .hero {
        position: absolute; top: 50%; transform: translateY(-50%);
        left: clamp(210px, 32vw, 460px);
        right: clamp(1.4rem, 6vw, 5rem);
        max-width: 760px;
      }
      .eyebrow { display: flex; align-items: center; gap: 0.9rem; color: var(--muted); margin-bottom: clamp(1rem, 2.5vw, 1.8rem); flex-wrap: wrap; }
      .eyebrow__sq { width: 11px; height: 11px; background: var(--accent); display: inline-block; }
      .eyebrow span:not(.eyebrow__sq):not(.eyebrow__rule) { color: var(--ink); }
      .eyebrow__rule { width: clamp(1.4rem, 4vw, 3rem); height: 1px; background: var(--muted); display: inline-block; }

      .title {
        font-family: var(--f-display);
        font-weight: 700;
        font-size: clamp(3.6rem, 11vw, 9.5rem);
        line-height: 0.9;
        letter-spacing: -0.035em;
        color: var(--ink);
      }
      .desc {
        margin-top: clamp(1.4rem, 3vw, 2.2rem);
        font-family: var(--f-display);
        font-weight: 400;
        font-size: clamp(1.05rem, 1.7vw, 1.6rem);
        line-height: 1.4;
        color: color-mix(in srgb, var(--ink) 80%, var(--bg-dark));
        max-width: 34ch;
      }

      .actions { margin-top: clamp(2rem, 4vw, 3rem); display: flex; align-items: center; gap: clamp(1.2rem, 3vw, 2.4rem); flex-wrap: wrap; }
      .btn {
        display: inline-flex; align-items: center; gap: 1rem;
        background: var(--ink); color: var(--bg-light);
        padding: 1.1rem 1.6rem; border-radius: 7px;
        transition: background 160ms ease;
      }
      .btn:hover { background: var(--accent); }
      .btn__rule { width: 1.6rem; height: 1px; background: currentColor; opacity: 0.6; }
      .link { display: inline-flex; align-items: center; gap: 0.8rem; color: var(--muted); transition: color 160ms ease; }
      .link:hover { color: var(--ink); }
      .link__rule { width: 1.6rem; height: 1px; background: var(--muted); }

      /* Footer plate */
      .plate {
        position: absolute; bottom: 0; left: 0; right: 0;
        display: flex; justify-content: space-between;
        padding: clamp(1.2rem, 3vw, 2.2rem) clamp(1.4rem, 4vw, 3.2rem);
        color: var(--muted); z-index: 4;
      }
      .plate span { font-size: 0.68rem; }
      .plate span:nth-child(2) { position: absolute; left: 50%; transform: translateX(-50%); }

      /* ---------- Responsive ---------- */
      @media (max-width: 900px) {
        .stage { min-height: 100svh; }
        .rail { display: none; }
        .spine { width: 8px; left: 0; }
        .spine::after, .spine__cross, .spine__text, .spine__dial, .spine__num { display: none; }
        .nav { display: none; }
        .hero {
          position: static; transform: none;
          padding: 8rem 1.6rem 7rem 2rem; left: auto; right: auto; max-width: none;
        }
        .title { font-size: clamp(3rem, 18vw, 6rem); }
        .desc { max-width: none; }
        .plate { flex-direction: column; gap: 0.4rem; align-items: flex-start; }
        .plate span:nth-child(2) { position: static; transform: none; }
      }
    </style>
  </body>
</html>
