---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { getSiteGlobal } from '../config/global';

const site = getSiteGlobal();
---

<Base title="Not found" description={site.notFoundMessage}>
  <section class="notfound">
    <div class="container container--narrow">
      <p class="notfound__code">404</p>
      <h1 class="notfound__title">{site.notFoundTitle}</h1>
      <p class="notfound__message">{site.notFoundMessage}</p>
      <a class="btn" href="/">Return home</a>
    </div>
  </section>
</Base>

<style>
  .notfound { padding-block: var(--s-16); text-align: center; }
  .notfound__code {
    font-family: var(--f-display);
    font-size: clamp(var(--t-4xl), 12vw, var(--t-6xl));
    color: var(--c-rule);
    line-height: 1;
    margin: 0;
  }
  .notfound__title {
    font-family: var(--f-display);
    font-size: clamp(var(--t-2xl), 5vw, var(--t-4xl));
    color: var(--c-ink-soft);
    margin: var(--s-4) 0 0 0;
  }
  .notfound__message {
    font-size: var(--t-md);
    color: var(--c-ink-mute);
    max-width: 44ch;
    margin: var(--s-5) auto var(--s-8);
    line-height: var(--ld-relaxed);
  }
</style>
