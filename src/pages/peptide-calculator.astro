---
/**
 * /tools/peptide-calculator
 * Standalone, self-contained interactive tool page.
 * Not editable in Keystatic by design — link to it from the admin via
 * Landing Page → Top navigation (slug: /tools/peptide-calculator).
 *
 * If you later want this wrapped in your site's shared header/footer,
 * import your layout and wrap the <main> in it.
 */
import PeptideCalculator from "../../components/PeptideCalculator.astro";

export const prerender = true;

const title = "Peptide Calculator";
const description =
  "Reconstitution calculator for peptide dosing on a U-100 insulin syringe. Runs entirely in your browser.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page">
      <header class="page-head">
        <a class="back" href="/">← Back</a>
        <h1>{title}</h1>
        <p class="sub">{description}</p>
      </header>

      <PeptideCalculator />

      <p class="disclaimer">
        For educational reference only. Not medical advice. Verify all dosing
        independently before use.
      </p>
    </main>

    <style>
      :root {
        --bg: #c7cbd0;
        --ink: #161b21;
        --muted: #5e6772;
        --accent: #0d9488;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: "Space Grotesk", system-ui, sans-serif;
        color: var(--ink);
        background:
          radial-gradient(120% 60% at 50% -10%, rgba(255,255,255,.85), transparent 55%),
          linear-gradient(168deg, #e2e5e9 0%, #cfd3d8 52%, #bfc3c9 100%);
        min-height: 100dvh;
      }
      .page {
        max-width: 480px;
        margin-inline: auto;
        padding: 24px 16px 40px;
      }
      .page-head { margin-bottom: 18px; }
      .back {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        letter-spacing: .5px;
        color: var(--muted);
        text-decoration: none;
      }
      .back:hover { color: var(--accent); }
      .page-head h1 {
        font-size: 22px;
        font-weight: 600;
        margin: 12px 0 6px;
      }
      .sub {
        font-size: 13.5px;
        color: var(--muted);
        line-height: 1.5;
        margin: 0;
      }
      .disclaimer {
        margin-top: 22px;
        font-family: "JetBrains Mono", monospace;
        font-size: 10.5px;
        line-height: 1.6;
        color: var(--muted);
        text-align: center;
      }
    </style>
  </body>
</html>
